<Window x:Class="SpotifyWPF.View.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:component="clr-namespace:SpotifyWPF.View.Component"
        Title="Infinite Jukebox"
        Width="288"
        Height="378"
        MinWidth="272"
        MinHeight="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        SnapsToDevicePixels="True">
    <component:MiniPlayerView HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"/>
</Window>
