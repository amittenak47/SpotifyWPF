<Window x:Class="SpotifyWPF.View.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:component="clr-namespace:SpotifyWPF.View.Component"
        Title="Infinite Jukebox"
        Width="288"
        Height="340"
        MinWidth="220"
        MinHeight="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        SnapsToDevicePixels="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="8"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <component:MiniPlayerView HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"/>
</Window>
