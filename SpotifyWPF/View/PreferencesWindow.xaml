<Window x:Class="SpotifyWPF.View.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences"
        Width="520"
        SizeToContent="Height"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Preferences"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="Customize the dark theme palette. Enter six-digit hex colors (for example, #750013)."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                   Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="420">
            <Grid x:Name="ColorFieldsGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
            </Grid>
        </ScrollViewer>

        <TextBlock Grid.Row="3"
                   Text="Visual effects"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,16,0,4"/>
        <StackPanel Grid.Row="4" Margin="0,0,0,4">
            <CheckBox x:Name="FractalBackgroundCheckBox"
                      Content="Fractal background (synced to the equalizer)"
                      Foreground="{DynamicResource AppForegroundBrush}"/>
            <TextBlock Text="Animated generative background behind the Infinite Jukebox ring and mini player. Off keeps the background pure black."
                       TextWrapping="Wrap"
                       Margin="20,4,0,0"
                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            <TextBlock Text="Equalizer preset"
                       Margin="0,12,0,4"
                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            <ComboBox x:Name="EqualizerPresetCombo"
                      MinWidth="220"
                      HorizontalAlignment="Left"
                      ToolTip="Cascading bars = Winamp segments. Wave ring = soft spectrum wave + cyan ticks."/>
            <TextBlock Text="Outer-ring music visualizer around the beat map."
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"
                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
        </StackPanel>

        <TextBlock x:Name="ValidationMessage"
                   Grid.Row="5"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource AppAccentBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Reset to Defaults"
                    Click="ResetToDefaults_Click"
                    Margin="0,0,8,0"
                    Padding="12,4"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    Padding="12,4"/>
            <Button Content="OK"
                    IsDefault="True"
                    Click="Ok_Click"
                    Padding="12,4"/>
        </StackPanel>
    </Grid>
</Window>
