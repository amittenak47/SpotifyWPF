<UserControl x:Class="SpotifyWPF.View.Page.PlaylistsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PlaylistsPage, Source={StaticResource Locator}}"
             d:DesignHeight="600" d:DesignWidth="800">

    <!-- List fills leftover space; Actions/Create/Info/Logs are Auto and yield when collapsed. -->
    <Grid Margin="6,4,6,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- List: search + playlist grid only -->
        <Expander x:Name="ListExpander"
                  Grid.Row="0"
                  Header="List"
                  Style="{StaticResource ControlPanelMenuExpanderStyle}"
                  IsExpanded="True"
                  VerticalAlignment="Stretch">
            <Grid Margin="0,2,0,0" MinHeight="160">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBox x:Name="PlaylistsSearchBox"
                             Text="{Binding PlaylistsFilterText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32"
                             VerticalContentAlignment="Center"
                             Padding="10,6"
                             HorizontalAlignment="Stretch"
                             ToolTip="Filter playlists"/>
                    <TextBlock Text="Search"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Foreground="{DynamicResource AppMutedForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=PlaylistsSearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=PlaylistsSearchBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <DataGrid x:Name="PlaylistsDataGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding CombinedPlaylists}"
                          SelectedItem="{Binding SelectedPlaylistRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionChanged="PlaylistsDataGrid_SelectionChanged"
                          PreviewKeyDown="PlaylistsDataGrid_PreviewKeyDown">
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick"
                                      Command="{Binding LoadTracksCommand}"
                                      CommandParameter="{Binding SelectedPlaylist}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open in Loop Lab"
                                      Command="{Binding OpenInLoopLabCommand}"
                                      CommandParameter="{Binding SelectedPlaylist}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeletionStatusName}" Value="Deleted">
                                    <Setter Property="Background" Value="#8B2E2E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DeletionStatusName}" Value="Failed">
                                    <Setter Property="Background" Value="#8A6D1D"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="*"/>
                        <DataGridTextColumn Header="Owner" Binding="{Binding OwnerDisplayName}" SortMemberPath="OwnerDisplayName" Width="*"/>
                        <DataGridTextColumn Header="# Tracks" Binding="{Binding TracksTotal}" SortMemberPath="TracksTotal" Width="Auto"/>
                        <DataGridTextColumn Header="Loaded" Binding="{Binding LoadedText}" SortMemberPath="LoadedText" Width="Auto"/>
                        <DataGridTextColumn Header="Queue" Binding="{Binding QueueStatus}" SortMemberPath="QueueStatus" Width="Auto"/>
                        <DataGridTextColumn Header="Delete Status" Binding="{Binding DeletionStatusName}" SortMemberPath="DeletionStatusName" Width="Auto"/>
                        <DataGridTextColumn Header="Spotify ID" Binding="{Binding Id}" SortMemberPath="Id" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Expander>

        <!-- Actions: file>menu style + Status/Abort live only here -->
        <Expander x:Name="ActionsExpander"
                  Grid.Row="1"
                  Header="Actions"
                  Style="{StaticResource ControlPanelMenuExpanderStyle}"
                  IsExpanded="False">
            <StackPanel Margin="0,2,0,4">
                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <TextBlock Text="Delay between requests"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   ToolTip="Milliseconds between Spotify API calls"/>
                        <TextBox Text="{Binding RequestSpacingMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                 Width="48"
                                 MinHeight="26"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <Button Content="{Binding ExecuteOrPauseButtonLabel}"
                                Command="{Binding ExecuteOrPauseCommand}"
                                Padding="12,4"/>
                    </StackPanel>

                    <Menu Background="Transparent" VerticalAlignment="Center">
                        <MenuItem Header="Load" Padding="8,4">
                            <StackPanel Margin="10,8" Width="260">
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Content="Load"
                                            MinWidth="52"
                                            MinHeight="28"
                                            Margin="8,0,0,0"
                                            Padding="10,4"
                                            Command="{Binding EnqueueLoadLimitCommand}"
                                            ToolTip="Enqueue loading the next page of playlists"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding PlaylistLoadLimit}"
                                               Width="28"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0"/>
                                    <Slider Style="{StaticResource DarkMediaSliderStyle}"
                                            Minimum="1"
                                            Maximum="50"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            Value="{Binding PlaylistLoadLimit, Mode=TwoWay}"
                                            ToolTip="Playlists per load page"/>
                                </DockPanel>
                            </StackPanel>
                            <MenuItem Header="Load all"
                                      Command="{Binding EnqueueLoadAllCommand}"
                                      ToolTip="Enqueue loading all remaining playlist pages"/>
                        </MenuItem>
                        <MenuItem Header="Delete" Padding="8,4">
                            <MenuItem Header="Selection"
                                      Command="{Binding ToggleDeleteQueueCommand}"
                                      CommandParameter="{Binding SelectedPlaylistItems}"
                                      ToolTip="Toggle selected playlists in/out of the deletion queue"/>
                            <MenuItem Header="All loaded"
                                      Command="{Binding DeleteAllToQueueCommand}"
                                      ToolTip="Enqueue all loaded playlists for deletion"/>
                        </MenuItem>
                        <MenuItem Header="Refresh"
                                  Padding="8,4"
                                  Command="{Binding RefreshDeletionResultsCommand}"
                                  ToolTip="Acknowledge or clear delete results"/>
                        <MenuItem Header="Export"
                                  Padding="8,4"
                                  Command="{Binding ExportToJsonCommand}"
                                  ToolTip="Export playlists to JSON"/>
                    </Menu>
                </DockPanel>

                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Content="Abort"
                            Command="{Binding CancelCurrentActionCommand}"
                            Padding="12,4"
                            Margin="8,0,0,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusActionConverter}}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   Foreground="{DynamicResource AppForegroundBrush}"/>
                        <ProgressBar Width="120"
                                     Height="8"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding ProgressVisibility}"/>
                    </StackPanel>
                </DockPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Height="140"
                              MinHeight="100"
                              MaxHeight="160">
                    <TreeView x:Name="QueuedActionsTreeView"
                              ItemsSource="{Binding QueuedActions}"
                              FontFamily="Consolas"
                              FontSize="11"
                              Background="Transparent"
                              BorderThickness="0"
                              PreviewKeyDown="QueuedActionsTreeView_PreviewKeyDown">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding DetailItems}">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Margin="4,1,0,1"/>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </StackPanel>
        </Expander>

        <!-- Create / Playlist Info (shared submenu) -->
        <Expander x:Name="CreateInfoExpander"
                  Grid.Row="2"
                  Header="Create / Playlist Info"
                  Style="{StaticResource ControlPanelMenuExpanderStyle}"
                  IsExpanded="False">
            <StackPanel Margin="4,2,4,6">
                <TextBlock Text="Create playlist"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                <DockPanel Margin="0,0,0,12" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <CheckBox Content="Public"
                                  IsChecked="{Binding NewPlaylistIsPublic}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                        <CheckBox Content="Collab"
                                  IsChecked="{Binding NewPlaylistIsCollaborative}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                        <Button Content="Create"
                                Command="{Binding CreatePlaylistCommand}"
                                MinWidth="52"
                                MinHeight="28"
                                Padding="10,4"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="28"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Playlist name"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewPlaylistDescription, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="28"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Description"/>
                    </Grid>
                </DockPanel>

                <DockPanel Margin="0,0,0,6" LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Content="Load Tracks"
                            Command="{Binding LoadTracksCommand}"
                            CommandParameter="{Binding SelectedPlaylist}"
                            Focusable="False"
                            MinWidth="88"
                            MinHeight="28"
                            Padding="10,4"
                            Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding TracksPlaylistTitle}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                </DockPanel>

                <DataGrid x:Name="TracksDataGrid"
                          ItemsSource="{Binding Tracks}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          BorderThickness="0"
                          MinHeight="72"
                          MaxHeight="180"
                          Height="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Position}" SortMemberPath="Position" Width="Auto"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding TrackName}" SortMemberPath="TrackName" Width="*"/>
                        <DataGridTextColumn Header="Artist(s)" Binding="{Binding Artists}" SortMemberPath="Artists" Width="*"/>
                        <DataGridTextColumn Header="Album" Binding="{Binding Album}" SortMemberPath="Album" Width="*"/>
                        <DataGridTextColumn Header="Disc #" Binding="{Binding DiscNumber}" SortMemberPath="DiscNumber" Width="Auto"/>
                        <DataGridTextColumn Header="Track #" Binding="{Binding TrackNumber}" SortMemberPath="TrackNumber" Width="Auto"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" SortMemberPath="Duration" Width="Auto"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding ItemType}" SortMemberPath="ItemType" Width="Auto"/>
                        <DataGridTextColumn Header="Spotify ID" Binding="{Binding SpotifyId}" SortMemberPath="SpotifyId" Width="*"/>
                        <DataGridTextColumn Header="Note" Binding="{Binding StatusNote}" SortMemberPath="StatusNote" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Expander>

        <!-- Logs -->
        <Expander x:Name="LogsExpander"
                  Grid.Row="3"
                  Header="Logs"
                  Style="{StaticResource ControlPanelMenuExpanderStyle}"
                  IsExpanded="False">
            <Border Height="160"
                    MinHeight="120"
                    MaxHeight="160"
                    Background="Transparent"
                    BorderThickness="0">
                <local:ActivityLogView DataContext="{Binding ActivityLog}"/>
            </Border>
        </Expander>
    </Grid>
</UserControl>
