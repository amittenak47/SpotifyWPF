<UserControl x:Class="SpotifyWPF.View.Page.PlaylistsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             mc:Ignorable="d"
             DataContext="{Binding PlaylistsPage, Source={StaticResource Locator}}"    
             d:DesignHeight="450" d:DesignWidth="800">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadPlaylistsCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem>
                <Label Content="{Binding Status}"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1" HorizontalContentAlignment="Stretch">
                <ProgressBar IsIndeterminate="True" Height="10" Visibility="{Binding ProgressVisibility}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Playlists" Margin="0,0,8,8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Load More" Command="{Binding LoadMorePlaylistsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                        <Button Content="Load All" Command="{Binding LoadAllPlaylistsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                        <Button Content="Export" Command="{Binding ExportToJsonCommand}" Padding="12,4" Margin="0,0,8,0"/>
                        <Button Content="Import" Command="{Binding ImportFromJsonCommand}" IsEnabled="False" Padding="12,4"/>
                    </StackPanel>

                    <DataGrid x:Name="PlaylistsDataGrid" ItemsSource="{Binding Playlists}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding LoadTracksCommand}"
                                          CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItem}"/>
                            <KeyBinding Key="Delete"
                                        Command="{Binding StagePlaylistsCommand}"
                                        CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"/>
                        </DataGrid.InputBindings>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Created By" Binding="{Binding Owner.DisplayName}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="# Tracks" Binding="{Binding Tracks.Total}" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8">
                <Button Content="-&gt;"
                        Command="{Binding StagePlaylistsCommand}"
                        CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"
                        Padding="12,4" Margin="0,0,0,8"/>
                <Button Content="&lt;-"
                        Command="{Binding UnstagePlaylistsCommand}"
                        CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"
                        Padding="12,4"/>
            </StackPanel>

            <GroupBox Grid.Column="2" Header="Staged For Deletion" Margin="0,0,0,8">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom"
                            Content="Delete Staged"
                            Command="{Binding DeletePlaylistsCommand}"
                            Padding="12,4"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"/>

                    <DataGrid x:Name="StagedForDeletionDataGrid" ItemsSource="{Binding StagedForDeletion}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete"
                                        Command="{Binding UnstagePlaylistsCommand}"
                                        CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"/>
                        </DataGrid.InputBindings>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Created By" Binding="{Binding Owner.DisplayName}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="# Tracks" Binding="{Binding Tracks.Total}" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.ColumnSpan="3" Header="Tracks">
                <DataGrid x:Name="TracksDataGrid" ItemsSource="{Binding Tracks}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding TrackName}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="Artist(s)" Binding="{Binding Artists}" IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="2"
                          Grid.ColumnSpan="3"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          ResizeDirection="Rows"/>

            <GroupBox Grid.Row="3" Grid.ColumnSpan="3" Margin="0,8,0,0">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Logs" VerticalAlignment="Center"/>
                        <TextBlock Text="Filter" VerticalAlignment="Center" Margin="16,0,4,0"/>
                        <ComboBox ItemsSource="{Binding LogFilterOptions}"
                                  SelectedItem="{Binding SelectedLogFilter}"
                                  Width="100"
                                  Padding="4,1"/>
                    </StackPanel>
                </GroupBox.Header>

                <ListBox ItemsSource="{Binding LogMessages}" FontFamily="Consolas" FontSize="11"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>
