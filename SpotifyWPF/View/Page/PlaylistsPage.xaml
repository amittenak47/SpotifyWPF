<UserControl x:Class="SpotifyWPF.View.Page.PlaylistsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             mc:Ignorable="d"
             DataContext="{Binding PlaylistsPage, Source={StaticResource Locator}}"    
             d:DesignHeight="450" d:DesignWidth="800">

    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem>
                <Label Content="{Binding Status, Converter={StaticResource StatusActionConverter}}"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1" HorizontalContentAlignment="Stretch">
                <ProgressBar IsIndeterminate="True" Height="10" Visibility="{Binding ProgressVisibility}"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="2">
                <StackPanel Orientation="Horizontal" Margin="8,0,4,0">
                    <Label Content="Request spacing (ms)" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding RequestSpacingMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                             Width="56"
                             VerticalContentAlignment="Center"
                             Margin="0,0,8,0"/>
                    <Button Content="{Binding ExecuteOrPauseButtonLabel}"
                            Command="{Binding ExecuteOrPauseCommand}"
                            Padding="12,3"
                            Margin="0,0,8,0"/>
                    <Button Content="Abort"
                            Command="{Binding CancelCurrentActionCommand}"
                            Padding="12,3"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Playlists" Margin="0,0,8,8">
                <DockPanel>
                    <GroupBox DockPanel.Dock="Top" Header="Create Playlist" Margin="0,0,0,8">
                        <WrapPanel Margin="4">
                            <Label Content="Name" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <Label Content="Description" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding NewPlaylistDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Width="260"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <CheckBox Content="Public"
                                      IsChecked="{Binding NewPlaylistIsPublic}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <CheckBox Content="Collaborative"
                                      IsChecked="{Binding NewPlaylistIsCollaborative}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <Button Content="Create"
                                    Command="{Binding CreatePlaylistCommand}"
                                    Padding="12,4"/>
                        </WrapPanel>
                    </GroupBox>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Label Content="Limit" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding PlaylistLoadLimit, UpdateSourceTrigger=PropertyChanged}"
                                 Width="44"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <Button Content="Load" Command="{Binding LoadMorePlaylistsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                        <Button Content="Load All" Command="{Binding LoadAllPlaylistsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                        <Button Content="Enqueue Load"
                                Command="{Binding EnqueueLoadLimitCommand}"
                                Focusable="False"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Enqueue Load All"
                                Command="{Binding EnqueueLoadAllCommand}"
                                Focusable="False"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Refresh Selected"
                                Command="{Binding RefreshSelectedPlaylistsCommand}"
                                CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Export" Command="{Binding ExportToJsonCommand}" Padding="12,4" Margin="0,0,8,0"/>
                        <Button Content="Import" Command="{Binding ImportFromJsonCommand}" IsEnabled="False" Padding="12,4"/>
                    </StackPanel>

                    <DataGrid x:Name="PlaylistsDataGrid"
                              ItemsSource="{Binding Playlists}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column">
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding LoadTracksCommand}"
                                          CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItem}"/>
                            <KeyBinding Key="Delete"
                                        Command="{Binding StagePlaylistsCommand}"
                                        CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"/>
                        </DataGrid.InputBindings>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Owner" Binding="{Binding OwnerDisplayName}" SortMemberPath="OwnerDisplayName" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="# Tracks" Binding="{Binding TracksTotal}" SortMemberPath="TracksTotal" IsReadOnly="True" Width="Auto"/>
                            <DataGridTextColumn Header="Spotify ID" Binding="{Binding Id}" SortMemberPath="Id" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GridSplitter Grid.Row="1"
                          Grid.ColumnSpan="3"
                          Height="8"
                          Background="{StaticResource SpotifyGreenLineBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeNS"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Rows"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8">
                <Button Content="-&gt;"
                        Command="{Binding StagePlaylistsCommand}"
                        CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"
                        Focusable="False"
                        Padding="12,4" Margin="0,0,0,8"/>
                <Button Content="&lt;-"
                        Command="{Binding UnstagePlaylistsCommand}"
                        CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"
                        Focusable="False"
                        Padding="12,4"/>
            </StackPanel>

            <GroupBox Grid.Column="2" Header="Staged For Deletion" Margin="0,0,0,8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Refresh"
                                Command="{Binding RefreshDeletionResultsCommand}"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Mark For Deletion"
                                Command="{Binding MarkForDeletionCommand}"
                                CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"
                                Focusable="False"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Unmark For Deletion"
                                Command="{Binding UnmarkForDeletionCommand}"
                                CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"
                                Focusable="False"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Enqueue Delete"
                                Command="{Binding EnqueueDeleteSelectionCommand}"
                                CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"
                                Focusable="False"
                                Padding="12,4"
                                Margin="0,0,8,0"/>
                        <Button Content="Delete"
                                Command="{Binding DeletePlaylistsCommand}"
                                Padding="12,4"/>
                    </StackPanel>

                    <DataGrid x:Name="StagedForDeletionDataGrid"
                              ItemsSource="{Binding StagedForDeletion}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column">
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DeletionStatusName}" Value="Deleted">
                                        <Setter Property="Background" Value="#8B2E2E"/>
                                        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DeletionStatusName}" Value="Failed">
                                        <Setter Property="Background" Value="#8A6D1D"/>
                                        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete"
                                        Command="{Binding UnstagePlaylistsCommand}"
                                        CommandParameter="{Binding ElementName=StagedForDeletionDataGrid, Path=SelectedItems}"/>
                        </DataGrid.InputBindings>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Playlist.Name}" SortMemberPath="Playlist.Name" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Owner" Binding="{Binding Playlist.OwnerDisplayName}" SortMemberPath="Playlist.OwnerDisplayName" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="# Tracks" Binding="{Binding Playlist.TracksTotal}" SortMemberPath="Playlist.TracksTotal" IsReadOnly="True" Width="Auto"/>
                            <DataGridTextColumn Header="Spotify ID" Binding="{Binding Playlist.Id}" SortMemberPath="Playlist.Id" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Queue" Binding="{Binding MarkStatus}" SortMemberPath="MarkStatus" IsReadOnly="True" Width="Auto"/>
                            <DataGridTextColumn Header="Delete Status" Binding="{Binding DeletionStatusName}" SortMemberPath="DeletionStatusName" IsReadOnly="True" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Row="2" Grid.ColumnSpan="3" Header="Tracks">
                <DataGrid x:Name="TracksDataGrid" ItemsSource="{Binding Tracks}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding TrackName}" SortMemberPath="TrackName" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="Artist(s)" Binding="{Binding Artists}" SortMemberPath="Artists" IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="3"
                          Grid.ColumnSpan="3"
                          Height="12"
                          Background="{StaticResource SpotifyGreenLineBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeNS"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Rows"/>

            <GroupBox Grid.Row="4" Grid.ColumnSpan="3" Margin="0,8,0,0">
                <TabControl>
                    <TabItem Header="Logs">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Filter"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox ItemsSource="{Binding LogFilterOptions}"
                                          SelectedItem="{Binding SelectedLogFilter}"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          Width="120"
                                          VerticalAlignment="Center"
                                          Padding="6,2"/>
                            </StackPanel>

                            <ListBox x:Name="LogMessagesListBox"
                                     ItemsSource="{Binding LogMessages}"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     SelectionMode="Extended">
                                <ListBox.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Copy Selected"
                                                  Command="{Binding CopySelectedLogMessagesCommand}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Copy All"
                                                  Command="{Binding CopyAllLogMessagesCommand}"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Actions">
                        <TreeView x:Name="QueuedActionsTreeView"
                                  ItemsSource="{Binding QueuedActions}"
                                  FontFamily="Consolas"
                                  FontSize="11"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  PreviewKeyDown="QueuedActionsTreeView_PreviewKeyDown">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding DetailItems}">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" Margin="4,1,0,1"/>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </TabItem>
                </TabControl>
            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>
