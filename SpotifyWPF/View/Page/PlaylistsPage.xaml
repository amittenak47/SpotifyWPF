<UserControl x:Class="SpotifyWPF.View.Page.PlaylistsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PlaylistsPage, Source={StaticResource Locator}}"
             d:DesignHeight="450" d:DesignWidth="800"
             MinWidth="720" MinHeight="400">

    <Grid Background="{DynamicResource AppBackgroundBrush}" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="8,8,8,0">
            <StatusBar DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem>
                    <Label Content="{Binding Status, Converter={StaticResource StatusActionConverter}}"/>
                </StatusBarItem>
                <StatusBarItem Grid.Column="1" HorizontalContentAlignment="Stretch">
                    <ProgressBar IsIndeterminate="True" Height="10" Visibility="{Binding ProgressVisibility}"/>
                </StatusBarItem>
                <StatusBarItem Grid.Column="2">
                    <StackPanel Orientation="Horizontal" Margin="8,0,4,0">
                        <Label Content="Delay between requests"
                               VerticalAlignment="Center"
                               ToolTip="Milliseconds between Spotify API calls"/>
                        <TextBox Text="{Binding RequestSpacingMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                 Width="48"
                                 VerticalContentAlignment="Center"
                                 Margin="4,0,8,0"
                                 ToolTip="Milliseconds between Spotify API calls"/>
                        <Button Content="{Binding ExecuteOrPauseButtonLabel}"
                                Command="{Binding ExecuteOrPauseCommand}"
                                Padding="12,3"
                                Margin="0,0,8,0"/>
                        <Button Content="Abort"
                                Command="{Binding CancelCurrentActionCommand}"
                                Padding="12,3"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <DockPanel>
                <!-- Unified toolbar: create + search + load/delete/enqueue/mark -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Create"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <TextBox Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="160"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,6,0"
                                     ToolTip="Playlist name"/>
                            <TextBox Text="{Binding NewPlaylistDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,6,0"
                                     ToolTip="Description"/>
                            <CheckBox Content="Public"
                                      IsChecked="{Binding NewPlaylistIsPublic}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <CheckBox Content="Collab"
                                      IsChecked="{Binding NewPlaylistIsCollaborative}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <Button Content="Create"
                                    Command="{Binding CreatePlaylistCommand}"
                                    Padding="12,4"/>
                        </WrapPanel>

                        <WrapPanel>
                            <TextBox Text="{Binding PlaylistsFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,6"
                                     ToolTip="Filter playlists"/>
                            <Button Content="Load"
                                    Command="{Binding EnqueueLoadLimitCommand}"
                                    Focusable="False"
                                    Padding="12,6"
                                    Margin="0,0,6,6"
                                    ToolTip="Enqueue load for the current Limit"/>
                            <TextBlock Text="Limit"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,6"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <TextBox Text="{Binding PlaylistLoadLimit, UpdateSourceTrigger=PropertyChanged}"
                                     Width="40"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,6,6"/>
                            <Button Content="Load All"
                                    Command="{Binding EnqueueLoadAllCommand}"
                                    Focusable="False"
                                    Padding="12,6"
                                    Margin="0,0,12,6"
                                    ToolTip="Enqueue load of all remaining playlist pages"/>
                            <Button Content="Delete"
                                    Command="{Binding ToggleDeleteQueueCommand}"
                                    CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"
                                    Focusable="False"
                                    Padding="12,6"
                                    Margin="0,0,6,6"
                                    ToolTip="Toggle selected playlists in/out of the deletion queue"/>
                            <Button Content="Delete All"
                                    Command="{Binding DeleteAllToQueueCommand}"
                                    Focusable="False"
                                    Padding="12,6"
                                    Margin="0,0,12,6"
                                    ToolTip="Enqueue all loaded playlists for deletion"/>
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCombinedCommand}"
                                    CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"
                                    Padding="12,6"
                                    Margin="0,0,6,6"/>
                            <Button Content="Export"
                                    Command="{Binding ExportToJsonCommand}"
                                    Padding="12,6"
                                    Margin="0,0,0,6"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="PlaylistsDataGrid"
                          ItemsSource="{Binding CombinedPlaylists}"
                          SelectedItem="{Binding SelectedPlaylistRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          BorderBrush="{DynamicResource AppBorderBrush}"
                          BorderThickness="1">
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick"
                                      Command="{Binding LoadTracksCommand}"
                                      CommandParameter="{Binding SelectedPlaylist}"/>
                        <KeyBinding Key="Delete"
                                    Command="{Binding ToggleDeleteQueueCommand}"
                                    CommandParameter="{Binding ElementName=PlaylistsDataGrid, Path=SelectedItems}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open in Loop Lab"
                                      Command="{Binding OpenInLoopLabCommand}"
                                      CommandParameter="{Binding SelectedPlaylist}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeletionStatusName}" Value="Deleted">
                                    <Setter Property="Background" Value="#8B2E2E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DeletionStatusName}" Value="Failed">
                                    <Setter Property="Background" Value="#8A6D1D"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="*"/>
                        <DataGridTextColumn Header="Owner" Binding="{Binding OwnerDisplayName}" SortMemberPath="OwnerDisplayName" Width="*"/>
                        <DataGridTextColumn Header="# Tracks" Binding="{Binding TracksTotal}" SortMemberPath="TracksTotal" Width="Auto"/>
                        <DataGridTextColumn Header="Loaded" Binding="{Binding LoadedText}" SortMemberPath="LoadedText" Width="Auto"/>
                        <DataGridTextColumn Header="Queue" Binding="{Binding QueueStatus}" SortMemberPath="QueueStatus" Width="Auto"/>
                        <DataGridTextColumn Header="Delete Status" Binding="{Binding DeletionStatusName}" SortMemberPath="DeletionStatusName" Width="Auto"/>
                        <DataGridTextColumn Header="Spotify ID" Binding="{Binding Id}" SortMemberPath="Id" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DockPanel>

        <component:PlaylistsControlPanel Grid.Row="1"
                                         Margin="8,0,8,8"
                                         ActivityLog="{Binding ActivityLog}"
                                         IsExpanded="{Binding IsControlsPanelExpanded, Mode=TwoWay}"
                                         ExpandedHeight="220"/>
    </Grid>
</UserControl>
