<UserControl x:Class="SpotifyWPF.View.Page.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- DataContext comes from MainWindow DataTemplate (LoginPageViewModel). Do not override here.
         Opacity/visibility of the form and the loading overlay are choreographed by
         LoginTransitionController (code-behind) from the view model's LoginPhase. -->
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <StackPanel x:Name="LoginFormPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="480"
                    Margin="24"
                    Panel.ZIndex="0"
                    IsEnabled="{Binding IsLoginFormEnabled}">
            <TextBlock Text="Bring Your Own Spotify App"
                       FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12">
                <Run Text="Enter your personal Spotify Client ID to log in."/>
                <LineBreak/>
                <Hyperlink NavigateUri="https://developer.spotify.com/dashboard"
                           Foreground="{DynamicResource AppAccentBrush}"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    Get your Client ID from the Spotify Developer Dashboard
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="Music Platform" Margin="0,0,0,4"/>
            <ComboBox SelectedIndex="0"
                      Style="{StaticResource DarkComboBoxStyle}"
                      HorizontalAlignment="Stretch"
                      Padding="6,4"
                      Margin="0,0,0,16">
                <ComboBoxItem Content="Spotify"/>
                <ComboBoxItem Content="Tidal" IsEnabled="False"/>
                <ComboBoxItem Content="Apple Music" IsEnabled="False"/>
            </ComboBox>

            <TextBlock Text="Client ID" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding SavedClientIds}"
                      Text="{Binding UserClientId, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      Style="{StaticResource DarkEditableComboBoxStyle}"
                      HorizontalAlignment="Stretch"
                      Padding="6,4"
                      Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Log In"
                        Command="{Binding SpotifyLoginCommand}"
                        Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Refresh / Reauthorize Token"
                        Command="{Binding RefreshSpotifyTokenCommand}"
                        Padding="16,6"/>
            </StackPanel>
        </StackPanel>

        <!-- Loading overlay: orbiting arc + pulsing core instead of a stock progress bar.
             Starts fully transparent and collapsed; LoginTransitionController fades it. -->
        <Border x:Name="LoadingOverlay"
                Panel.ZIndex="1"
                Background="#F2000000"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="280">
                <Grid Width="72" Height="72" Margin="0,0,0,20" HorizontalAlignment="Center">
                    <!-- Faint track ring -->
                    <Ellipse Stroke="#26FFFFFF" StrokeThickness="3"/>

                    <!-- Orbiting arc segment (one dash of the circumference, spun forever) -->
                    <Ellipse Stroke="{DynamicResource AppAccentBrush}"
                             StrokeThickness="3"
                             StrokeDashArray="16 57"
                             StrokeDashCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Pulsing core -->
                    <Ellipse x:Name="SpinnerCore"
                             Width="12" Height="12"
                             Fill="{DynamicResource AppAccentBrush}"
                             RenderTransformOrigin="0.5,0.5"
                             Opacity="0.9">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="SpinnerCoreScale" ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:1.4"
                                                     RepeatBehavior="Forever"/>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerCoreScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     From="0.72" To="1.18"
                                                     Duration="0:0:0.9"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerCoreScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     From="0.72" To="1.18"
                                                     Duration="0:0:0.9"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerCore"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.55" To="1"
                                                     Duration="0:0:0.9"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
                </Grid>

                <TextBlock x:Name="LoginStatusTextBlock"
                           Text="{Binding LoginStatusText, NotifyOnTargetUpdated=True}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
