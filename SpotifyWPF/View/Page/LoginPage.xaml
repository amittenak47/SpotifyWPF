<UserControl x:Class="SpotifyWPF.View.Page.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- DataContext comes from MainWindow DataTemplate (LoginPageViewModel). Do not override here. -->
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="480"
                    Margin="24"
                    Panel.ZIndex="0"
                    IsEnabled="{Binding IsLoginFormEnabled}">
            <TextBlock Text="Bring Your Own Spotify App"
                       FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12">
                <Run Text="Enter your personal Spotify Client ID to log in."/>
                <LineBreak/>
                <Hyperlink NavigateUri="https://developer.spotify.com/dashboard"
                           Foreground="{DynamicResource AppAccentBrush}"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    Get your Client ID from the Spotify Developer Dashboard
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="Music Platform" Margin="0,0,0,4"/>
            <ComboBox SelectedIndex="0"
                      Style="{StaticResource DarkComboBoxStyle}"
                      HorizontalAlignment="Stretch"
                      Padding="6,4"
                      Margin="0,0,0,16">
                <ComboBoxItem Content="Spotify"/>
                <ComboBoxItem Content="Tidal" IsEnabled="False"/>
                <ComboBoxItem Content="Apple Music" IsEnabled="False"/>
            </ComboBox>

            <TextBlock Text="Client ID" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding SavedClientIds}"
                      Text="{Binding UserClientId, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      Style="{StaticResource DarkEditableComboBoxStyle}"
                      HorizontalAlignment="Stretch"
                      Padding="6,4"
                      Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Log In"
                        Command="{Binding SpotifyLoginCommand}"
                        Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Refresh / Reauthorize Token"
                        Command="{Binding RefreshSpotifyTokenCommand}"
                        Padding="16,6"/>
            </StackPanel>
        </StackPanel>

        <Border Panel.ZIndex="1"
                Background="#E6000000"
                Visibility="{Binding IsLoggingIn,
                                     Converter={StaticResource BooleanToVisibilityConverter},
                                     FallbackValue=Collapsed,
                                     TargetNullValue=Collapsed}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="280">
                <ProgressBar IsIndeterminate="True" Height="8" Margin="0,0,0,16"/>
                <TextBlock Text="{Binding LoginStatusText}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Panel.ZIndex="2"
                Background="{DynamicResource AppBackgroundBrush}"
                Visibility="{Binding ShowLoginBridge,
                                     Converter={StaticResource BooleanToVisibilityConverter},
                                     FallbackValue=Collapsed,
                                     TargetNullValue=Collapsed}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Signed in"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}"/>
                <TextBlock Text="Loading your library..."
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
