<UserControl x:Class="SpotifyWPF.View.Page.AlbumsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             DataContext="{Binding AlbumsPage, Source={StaticResource Locator}}"
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel Margin="8" Background="{DynamicResource AppBackgroundBrush}">
        <GroupBox DockPanel.Dock="Top" Header="Saved Albums" Margin="0,0,0,8">
            <WrapPanel Margin="4">
                <Button Content="Load Next Page" Command="{Binding LoadAlbumsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Load All" Command="{Binding LoadAllAlbumsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Refresh Selected"
                        Command="{Binding RefreshSelectedAlbumsCommand}"
                        CommandParameter="{Binding ElementName=AlbumsDataGrid, Path=SelectedItems}"
                        Padding="12,4"
                        Margin="0,0,8,0"/>
                <Button Content="Remove Selected"
                        Command="{Binding RemoveSelectedAlbumsCommand}"
                        CommandParameter="{Binding ElementName=AlbumsDataGrid, Path=SelectedItems}"
                        Padding="12,4"
                        Margin="0,0,8,0"/>
                <Label Content="Filter:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Width="220" VerticalContentAlignment="Center"/>
            </WrapPanel>
        </GroupBox>

        <DataGrid x:Name="AlbumsDataGrid"
                  ItemsSource="{Binding Albums}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Artist(s)" Binding="{Binding Artists}" Width="*"/>
                <DataGridTextColumn Header="# Tracks" Binding="{Binding TotalTracks}" Width="Auto"/>
                <DataGridTextColumn Header="Release Date" Binding="{Binding ReleaseDate}" Width="Auto"/>
                <DataGridTextColumn Header="Added At" Binding="{Binding AddedAt}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
