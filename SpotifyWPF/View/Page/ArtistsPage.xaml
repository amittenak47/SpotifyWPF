<UserControl x:Class="SpotifyWPF.View.Page.ArtistsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             DataContext="{Binding ArtistsPage, Source={StaticResource Locator}}"
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel Margin="8" Background="{StaticResource AppBackgroundBrush}">
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <Label Content="{Binding Status, Converter={StaticResource StatusActionConverter}}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <ProgressBar IsIndeterminate="True" Height="10" Visibility="{Binding ProgressVisibility}"/>
            </StatusBarItem>
            <StatusBarItem>
                <Button Content="Abort"
                        Command="{Binding CancelCurrentActionCommand}"
                        Padding="12,3"
                        Margin="8,0,4,0"/>
            </StatusBarItem>
        </StatusBar>

        <GroupBox DockPanel.Dock="Top" Header="Followed Artists" Margin="0,0,0,8">
            <WrapPanel Margin="4">
                <Button Content="Load Next Page" Command="{Binding LoadArtistsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Load All" Command="{Binding LoadAllArtistsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Refresh Selected"
                        Command="{Binding RefreshSelectedArtistsCommand}"
                        CommandParameter="{Binding ElementName=ArtistsDataGrid, Path=SelectedItems}"
                        Padding="12,4"
                        Margin="0,0,8,0"/>
                <Button Content="Unfollow Selected"
                        Command="{Binding UnfollowSelectedArtistsCommand}"
                        CommandParameter="{Binding ElementName=ArtistsDataGrid, Path=SelectedItems}"
                        Padding="12,4"
                        Margin="0,0,8,0"/>
                <Label Content="Filter:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Width="220" VerticalContentAlignment="Center"/>
            </WrapPanel>
        </GroupBox>

        <DataGrid x:Name="ArtistsDataGrid"
                  ItemsSource="{Binding Artists}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Followers" Binding="{Binding FollowersTotal}" Width="Auto"/>
                <DataGridTextColumn Header="Popularity" Binding="{Binding Popularity}" Width="Auto"/>
                <DataGridTextColumn Header="Genres" Binding="{Binding Genres}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
