<UserControl x:Class="SpotifyWPF.View.Page.PredictionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"
             Loaded="PredictionPage_Loaded"
             Unloaded="PredictionPage_Unloaded"
             d:DesignHeight="450" d:DesignWidth="800"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="8" Background="{DynamicResource AppBackgroundBrush}" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceAltBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Padding="8"
                Margin="0,0,0,8"
                Visibility="{Binding HasPlayerInitializationError,
                                     Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding PlayerInitializationError}"
                       TextWrapping="Wrap"
                       Foreground="#E05545"/>
        </Border>

        <!-- Main stage fills the black area; title/status overlay on top -->
        <Border x:Name="StageHost"
                Grid.Row="1"
                Background="{DynamicResource AppBackgroundBrush}"
                ClipToBounds="True"
                Panel.ZIndex="0"
                PreviewMouseWheel="StageHost_PreviewMouseWheel">
            <Grid>
                <component:FractalBackgroundControl IsActive="{Binding IsFractalBackgroundEnabled}"
                                                    EnergyProvider="{Binding VisualEnergy}"
                                                    Opacity="0.9"
                                                    IsHitTestVisible="False"/>

                <Viewbox x:Name="StageViewbox"
                         Stretch="Uniform"
                         StretchDirection="Both"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Margin="12,4">
                    <Grid x:Name="StageRoot"
                          Width="560"
                          Height="596"
                          RenderTransformOrigin="0.5,0.5"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="560"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="SearchHoverZone"
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Padding="0,4"
                                Background="Transparent"
                                Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                MouseEnter="HoverZone_MouseEnter"
                                MouseLeave="HoverZone_MouseLeave">
                            <StackPanel>
                                <TextBox x:Name="TrackSearchBox"
                                         Width="560"
                                         Opacity="0.35"
                                         Text="{Binding TrackInput, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         HorizontalAlignment="Center"
                                         FontSize="13"
                                         Padding="8,4"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         CaretBrush="{DynamicResource AppForegroundBrush}"
                                         Foreground="{DynamicResource AppForegroundBrush}"
                                         ToolTip="Track ID, URI, or Spotify link — press Enter to play"
                                         PreviewKeyDown="TrackSearchBox_PreviewKeyDown"/>
                                <TextBlock Text="{Binding RingPlaybackRateText}"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,2,0,0"
                                           IsHitTestVisible="False"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                                           ToolTip="Local WAV playback speed — drag the center disc to change; snaps to 1.00×">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRingPlaybackRateModified}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 To="0.85" Duration="0:0:0.18"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 To="0" Duration="0:0:0.28"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1"
                              Width="560"
                              Height="560"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <component:JukeboxRingView x:Name="RingView"
                                                       Width="560"
                                                       Height="560"
                                                       OwnsWheelZoom="False"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       DataContext="{Binding}"/>

                            <!-- Play/pause only — keep small so the gray disc can receive hold-to-scan. -->
                            <Border x:Name="WheelHoverZone"
                                    Width="44"
                                    Height="44"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Panel.ZIndex="20"
                                    Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    MouseEnter="HoverZone_MouseEnter"
                                    MouseLeave="HoverZone_MouseLeave">
                                <component:TransportWheelControl x:Name="TransportWheel"
                                                                 Width="40"
                                                                 Height="40"
                                                                 Opacity="0.28"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 DataContext="{Binding}"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Viewbox>

                <!-- Scrubber clock footnote -->
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,14,10"
                           Panel.ZIndex="30"
                           FontSize="11"
                           Opacity="0.7"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           Text="{Binding PositionText}"
                           Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Title + status + SSM stacked top-left (SSM below details, not over them) -->
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="12,8,0,0"
                            MaxWidth="420"
                            Panel.ZIndex="30"
                            Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="True">
                        <TextBlock Text="Infinite Jukebox"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForegroundBrush}"/>
                        <TextBlock Text=" by "
                                   FontSize="12"
                                   Margin="6,0,0,3"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                        <TextBlock FontSize="12"
                                   Margin="0,0,0,3"
                                   VerticalAlignment="Bottom">
                            <Hyperlink NavigateUri="https://musicmachinery.com/2012/11/12/the-infinite-jukebox/"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       RequestNavigate="PaulLamereLink_RequestNavigate">
                                Paul Lamere
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- Always-visible track title — constrained width so marquee can scroll R→L -->
                    <Grid Height="20"
                          Margin="0,6,0,0"
                          MaxWidth="400"
                          HorizontalAlignment="Left"
                          ClipToBounds="True"
                          IsHitTestVisible="True">
                        <TextBlock Text="{Binding Status}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <component:MarqueeTextBlock Text="{Binding NowPlayingMarqueeText}"
                                                    AlwaysScroll="True"
                                                    Height="20"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Stretch"
                                                    Foreground="{DynamicResource AppForegroundBrush}">
                            <component:MarqueeTextBlock.Style>
                                <Style TargetType="{x:Type component:MarqueeTextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </component:MarqueeTextBlock.Style>
                        </component:MarqueeTextBlock>
                    </Grid>

                    <!-- Optional status HUD: dim until hovered, under the title -->
                    <Border x:Name="StatusHoverZone"
                            Margin="0,8,0,0"
                            Padding="10,8"
                            CornerRadius="4"
                            Background="#CC0A0A0C"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1"
                            Opacity="0.35"
                            MouseEnter="HoverZone_MouseEnter"
                            MouseLeave="HoverZone_MouseLeave">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowStatusOverlay}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left"
                                           Width="72"
                                           FontSize="11"
                                           Text="Cache"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentTrackCacheStatusText}"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                            </DockPanel>
                            <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left"
                                           Width="72"
                                           FontSize="11"
                                           Text="Graph"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                <TextBlock FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="{Binding RingSegmentCountText}"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                            </DockPanel>
                            <TextBlock FontSize="11"
                                       Margin="0,0,0,6"
                                       TextWrapping="Wrap"
                                       Text="{Binding ElementName=RingView, Path=Ring.HudText}"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left"
                                           Width="72"
                                           FontSize="11"
                                           Text="Chance"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                <TextBlock FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="{Binding JukeboxBranchChanceText}"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                            </DockPanel>
                            <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left"
                                           Width="72"
                                           FontSize="11"
                                           Text="Source"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                <TextBlock FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentTrackAnalysisDetailText}"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                            </DockPanel>
                            <DockPanel LastChildFill="True" Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left"
                                           Width="72"
                                           FontSize="11"
                                           Text="Transport"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                <TextBlock FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="{Binding DeviceText}"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                            </DockPanel>
                            <CheckBox Content="Show similarity map (SSM)"
                                      FontSize="11"
                                      IsChecked="{Binding ShowSsmHeatmap}"
                                      Foreground="{DynamicResource AppForegroundBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ProgressBar Width="72"
                                             Height="4"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             Maximum="100"
                                             Value="{Binding AnalysisProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsIndeterminateAnalysisProgress, Mode=OneWay}"/>
                                <TextBlock Text="{Binding AnalysisStatusText}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           MaxWidth="280"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppAccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SSM sits in the same column, below status — not absolutely overlaid -->
                    <Border Margin="0,10,0,0"
                            Padding="8"
                            Width="200"
                            Height="200"
                            HorizontalAlignment="Left"
                            Background="#F00C0C0E"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1"
                            Visibility="{Binding ShowSsmHeatmap, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Self-similarity"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,2"
                                       Foreground="{DynamicResource AppForegroundBrush}"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Bright = similar · stripes = repeats"
                                       FontSize="9"
                                       Margin="0,0,0,6"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="Click a row to inspect that beat"
                                       FontSize="9"
                                       Margin="0,6,0,0"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <component:SelfSimilarityHeatmapControl
                                StackedFeatures="{Binding RingStackedFeatures}"
                                HighlightBeatIndex="{Binding RingInspectBeat, Mode=OneWay}"
                                SelectedBeatIndex="{Binding RingInspectBeat, Mode=TwoWay}"/>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Manual select confirm/cancel — window chrome, not trapped in the ring Viewbox -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,16,36"
                            Panel.ZIndex="40"
                            Visibility="{Binding IsManualBranchSelect, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="Cancel"
                            MinWidth="88"
                            MinHeight="32"
                            Margin="0,0,8,0"
                            Click="ManualCancel_Click"
                            ToolTip="Discard the hop chain"/>
                    <Button Content="Confirm hops"
                            MinWidth="110"
                            MinHeight="32"
                            Click="ManualConfirm_Click"
                            Background="#1DB954"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Lock the selected hop chain"/>
                </StackPanel>

                <Border x:Name="PlayerHostBorder"
                        Width="1" Height="1"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Peek strip / slide-up Controls at the bottom edge -->
        <component:LoopLabBottomPanel Grid.Row="2"
                                      Panel.ZIndex="40"
                                      ActivityLog="{Binding ActivityLog}"
                                      IsExpanded="{Binding IsBottomPanelExpanded, Mode=TwoWay}"
                                      ExpandedHeight="{Binding BottomPanelHeight, Mode=TwoWay}"
                                      Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>
