<UserControl x:Class="SpotifyWPF.View.Page.PredictionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"
             Loaded="PredictionPage_Loaded"
             Unloaded="PredictionPage_Unloaded"
             d:DesignHeight="450" d:DesignWidth="800"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <DockPanel Margin="8" Background="{DynamicResource AppBackgroundBrush}">
        <StatusBar DockPanel.Dock="Bottom"
                   Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StatusBarItem Width="300">
                <Grid Height="18" ClipToBounds="True">
                    <TextBlock Text="{Binding Status}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <component:MarqueeTextBlock Text="{Binding NowPlayingMarqueeText}"
                                                Height="18"
                                                Foreground="{DynamicResource AppForegroundBrush}">
                        <component:MarqueeTextBlock.Style>
                            <Style TargetType="{x:Type component:MarqueeTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </component:MarqueeTextBlock.Style>
                    </component:MarqueeTextBlock>
                </Grid>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=RingView, Path=Ring.HudText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding RingSegmentCountText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding JukeboxBranchChanceText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Label Content="{Binding AnalysisSourceText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="72"
                                 Height="4"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Maximum="100"
                                 Value="{Binding AnalysisProgressPercent, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsIndeterminateAnalysisProgress, Mode=OneWay}"/>
                    <TextBlock Text="{Binding AnalysisStatusText}"
                               VerticalAlignment="Center"
                               MaxWidth="280"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource AppAccentBrush}"/>
                </StackPanel>
                <StatusBarItem.Style>
                    <Style TargetType="StatusBarItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StatusBarItem.Style>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Label Content="{Binding DeviceText}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12"
                        Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Infinite Jukebox"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppForegroundBrush}"/>
                    <TextBlock Text=" by "
                               FontSize="13"
                               Margin="6,0,0,4"
                               VerticalAlignment="Bottom"
                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                    <TextBlock FontSize="13"
                               Margin="0,0,0,4"
                               VerticalAlignment="Bottom">
                        <Hyperlink NavigateUri="https://musicmachinery.com/2012/11/12/the-infinite-jukebox/"
                                   Foreground="{DynamicResource AppAccentBrush}"
                                   RequestNavigate="PaulLamereLink_RequestNavigate">
                            Paul Lamere
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasPlayerInitializationError,
                                                 Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding PlayerInitializationError}"
                                   TextWrapping="Wrap"
                                   Foreground="#E05545"/>
                    </Border>

                    <!-- Main stage: search above ring, scrubber + transport wheel below -->
                    <Border x:Name="StageHost"
                            Grid.Row="2"
                            Margin="0,0,0,8"
                            Background="{DynamicResource AppBackgroundBrush}"
                            ClipToBounds="True"
                            Panel.ZIndex="0"
                            SizeChanged="StageHost_SizeChanged">
                        <Grid>
                            <component:FractalBackgroundControl IsActive="{Binding IsFractalBackgroundEnabled}"
                                                                EnergyProvider="{Binding VisualEnergy}"
                                                                Opacity="0.9"
                                                                IsHitTestVisible="False"/>

                            <Grid x:Name="StageRoot"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="24,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="SearchHoverZone"
                                        Grid.Row="0"
                                        Margin="0,0,0,10"
                                        Padding="0,6"
                                        Background="#01FFFFFF"
                                        Opacity="0.18"
                                        Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        MouseEnter="HoverZone_MouseEnter"
                                        MouseLeave="HoverZone_MouseLeave">
                                    <TextBox x:Name="TrackSearchBox"
                                             Width="{Binding ActualWidth, ElementName=RingStage}"
                                             MinWidth="200"
                                             Text="{Binding TrackInput, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"
                                             HorizontalAlignment="Center"
                                             Background="Transparent"
                                             BorderBrush="{DynamicResource AppBorderBrush}"
                                             BorderThickness="0,0,0,1"
                                             CaretBrush="{DynamicResource AppForegroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             ToolTip="Track ID, URI, or Spotify link — press Enter to play"
                                             PreviewKeyDown="TrackSearchBox_PreviewKeyDown"/>
                                </Border>

                                <Grid x:Name="RingStage"
                                      Grid.Row="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      MinWidth="160"
                                      MinHeight="160">
                                    <component:JukeboxRingView x:Name="RingView"
                                                               HorizontalAlignment="Stretch"
                                                               VerticalAlignment="Stretch"
                                                               DataContext="{Binding}"/>
                                </Grid>

                                <Border x:Name="ScrubberHoverZone"
                                        Grid.Row="2"
                                        Margin="0,10,0,0"
                                        Padding="0,8"
                                        Background="#01FFFFFF"
                                        Opacity="0.18"
                                        Width="{Binding ActualWidth, ElementName=RingStage}"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        MouseEnter="HoverZone_MouseEnter"
                                        MouseLeave="HoverZone_MouseLeave">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Slider Grid.Column="0"
                                                Style="{StaticResource DarkMediaSliderStyle}"
                                                Minimum="0"
                                                Maximum="{Binding DurationMs, Mode=OneWay}"
                                                Value="{Binding ScrubberPositionMs, Mode=TwoWay}"
                                                IsMoveToPointEnabled="True"
                                                IsEnabled="{Binding HasScrubbableTrack}"
                                                VerticalAlignment="Center"
                                                Loaded="Scrubber_Loaded"
                                                PreviewMouseLeftButtonDown="Scrubber_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="Scrubber_PreviewMouseLeftButtonUp"
                                                LostMouseCapture="Scrubber_LostMouseCapture"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PositionText}"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                    </Grid>
                                </Border>

                                <component:TransportWheelControl Grid.Row="3"
                                                                 Margin="0,12,0,4"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 DataContext="{Binding}"
                                                                 Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>

                            <Border x:Name="PlayerHostBorder"
                                    Width="1" Height="1"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <component:LoopLabBottomPanel Grid.Row="3"
                                                    Panel.ZIndex="2"
                                                    ActivityLog="{Binding ActivityLog}"
                                                    IsExpanded="{Binding IsBottomPanelExpanded, Mode=TwoWay}"
                                                    ExpandedHeight="{Binding BottomPanelHeight, Mode=TwoWay}"
                                                    Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </DockPanel>
</UserControl>
