<UserControl x:Class="SpotifyWPF.View.Page.PredictionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"
             Loaded="PredictionPage_Loaded"
             Unloaded="PredictionPage_Unloaded"
             d:DesignHeight="450" d:DesignWidth="800"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="TransportIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="8" Background="{DynamicResource AppBackgroundBrush}">
        <StatusBar DockPanel.Dock="Bottom"
                   Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StatusBarItem Width="300">
                <Grid Height="18" ClipToBounds="True">
                    <TextBlock Text="{Binding Status}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <component:MarqueeTextBlock Text="{Binding NowPlayingMarqueeText}"
                                                Height="18"
                                                Foreground="{DynamicResource AppForegroundBrush}">
                        <component:MarqueeTextBlock.Style>
                            <Style TargetType="{x:Type component:MarqueeTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </component:MarqueeTextBlock.Style>
                    </component:MarqueeTextBlock>
                </Grid>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=RingView, Path=Ring.HudText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding RingSegmentCountText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding JukeboxBranchChanceText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Label Content="{Binding AnalysisSourceText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Label Content="{Binding DeviceText}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12"
                        Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Infinite Jukebox"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppForegroundBrush}"/>
                    <TextBlock Text=" by "
                               FontSize="13"
                               Margin="6,0,0,4"
                               VerticalAlignment="Bottom"
                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                    <TextBlock FontSize="13"
                               Margin="0,0,0,4"
                               VerticalAlignment="Bottom">
                        <Hyperlink NavigateUri="https://musicmachinery.com/2012/11/12/the-infinite-jukebox/"
                                   Foreground="{DynamicResource AppAccentBrush}"
                                   RequestNavigate="PaulLamereLink_RequestNavigate">
                            Paul Lamere
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasPlayerInitializationError,
                                                 Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding PlayerInitializationError}"
                                   TextWrapping="Wrap"
                                   Foreground="#E05545"/>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding TrackInput, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Track ID, spotify:track: URI, or open.spotify.com link"/>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource TransportIconButtonStyle}"
                                            Command="{Binding PreviousSessionTrackCommand}">
                                        <TextBlock Text="&#xE892;" Style="{StaticResource TransportGlyphStyle}"/>
                                    </Button>

                                    <Button Style="{StaticResource TransportIconButtonStyle}"
                                            Command="{Binding TogglePlayPauseCommand}">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TransportGlyphStyle}">
                                                    <Setter Property="Text" Value="&#xE768;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowPauseIcon}" Value="True">
                                                            <Setter Property="Text" Value="&#xE769;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>

                                    <Button Style="{StaticResource TransportIconButtonStyle}"
                                            Command="{Binding StopPlaybackCommand}">
                                        <TextBlock Text="&#xE71A;" Style="{StaticResource TransportGlyphStyle}"/>
                                    </Button>

                                    <Button Style="{StaticResource TransportIconButtonStyle}"
                                            Command="{Binding NextSessionTrackCommand}">
                                        <TextBlock Text="&#xE893;" Style="{StaticResource TransportGlyphStyle}"/>
                                    </Button>

                                    <Button Style="{StaticResource TransportIconButtonStyle}"
                                            Command="{Binding EnterMiniPlayerCommand}">
                                        <TextBlock Text="&#xE919;" Style="{StaticResource TransportGlyphStyle}"/>
                                    </Button>

                                    <Button Content="Analyze"
                                            MinWidth="72"
                                            Margin="8,0,0,0"
                                            Command="{Binding AnalyzeInputCommand}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Slider Grid.Column="0"
                                        Style="{StaticResource DarkMediaSliderStyle}"
                                        Minimum="0"
                                        Maximum="{Binding DurationMs, Mode=OneWay}"
                                        Value="{Binding ScrubberPositionMs, Mode=TwoWay}"
                                        IsMoveToPointEnabled="True"
                                        IsEnabled="{Binding HasScrubbableTrack}"
                                        VerticalAlignment="Center"
                                        Loaded="Scrubber_Loaded"
                                        PreviewMouseLeftButtonDown="Scrubber_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="Scrubber_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="Scrubber_LostMouseCapture"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding PositionText}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Large centered ring (scroll wheel zooms in/out on the black area; clipped above control panel) -->
                    <Border Grid.Row="3"
                            Margin="0,0,0,8"
                            Background="{DynamicResource AppBackgroundBrush}"
                            ClipToBounds="True"
                            Panel.ZIndex="0">
                        <Grid>
                            <component:JukeboxRingView x:Name="RingView"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       DataContext="{Binding}"/>
                            <Border x:Name="PlayerHostBorder"
                                    Width="1" Height="1"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <component:LoopLabBottomPanel Grid.Row="4"
                                                    Panel.ZIndex="2"
                                                    ActivityLog="{Binding ActivityLog}"
                                                    IsExpanded="{Binding IsBottomPanelExpanded, Mode=TwoWay}"
                                                    ExpandedHeight="{Binding BottomPanelHeight, Mode=TwoWay}"
                                                    Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </DockPanel>
</UserControl>
