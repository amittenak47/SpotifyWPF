<UserControl x:Class="SpotifyWPF.View.Page.PredictionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"
             Loaded="PredictionPage_Loaded"
             Unloaded="PredictionPage_Unloaded"
             d:DesignHeight="450" d:DesignWidth="800"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="8" Background="{DynamicResource AppBackgroundBrush}" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceAltBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Padding="8"
                Margin="0,0,0,8"
                Visibility="{Binding HasPlayerInitializationError,
                                     Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding PlayerInitializationError}"
                       TextWrapping="Wrap"
                       Foreground="#E05545"/>
        </Border>

        <!-- Main stage fills the black area; title/status overlay on top -->
        <Border x:Name="StageHost"
                Grid.Row="1"
                Background="{DynamicResource AppBackgroundBrush}"
                ClipToBounds="True"
                Panel.ZIndex="0"
                PreviewMouseWheel="StageHost_PreviewMouseWheel">
            <Grid>
                <component:FractalBackgroundControl IsActive="{Binding IsFractalBackgroundEnabled}"
                                                    EnergyProvider="{Binding VisualEnergy}"
                                                    Opacity="0.9"
                                                    IsHitTestVisible="False"/>

                <Viewbox x:Name="StageViewbox"
                         Stretch="Uniform"
                         StretchDirection="Both"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Margin="12,4">
                    <Grid x:Name="StageRoot"
                          Width="560"
                          Height="646"
                          RenderTransformOrigin="0.5,0.5"
                          Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="560"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="SearchHoverZone"
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Padding="0,4"
                                Background="#01FFFFFF"
                                Opacity="0.18"
                                Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                MouseEnter="HoverZone_MouseEnter"
                                MouseLeave="HoverZone_MouseLeave">
                            <TextBox x:Name="TrackSearchBox"
                                     Width="560"
                                     Text="{Binding TrackInput, UpdateSourceTrigger=PropertyChanged}"
                                     TextAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     HorizontalAlignment="Center"
                                     FontSize="13"
                                     Padding="8,4"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="{DynamicResource AppForegroundBrush}"
                                     Foreground="{DynamicResource AppForegroundBrush}"
                                     ToolTip="Track ID, URI, or Spotify link — press Enter to play"
                                     PreviewKeyDown="TrackSearchBox_PreviewKeyDown"/>
                        </Border>

                        <Grid Grid.Row="1"
                              Width="560"
                              Height="560"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <component:JukeboxRingView x:Name="RingView"
                                                       Width="560"
                                                       Height="560"
                                                       OwnsWheelZoom="False"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       DataContext="{Binding}"/>

                            <!-- Transparent playback wheel in the ring hole; fades in on hover -->
                            <Border x:Name="WheelHoverZone"
                                    Width="120"
                                    Height="120"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#01FFFFFF"
                                    Opacity="0.18"
                                    Panel.ZIndex="20"
                                    Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    MouseEnter="HoverZone_MouseEnter"
                                    MouseLeave="HoverZone_MouseLeave">
                                <component:TransportWheelControl x:Name="TransportWheel"
                                                                 Width="80"
                                                                 Height="80"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 DataContext="{Binding}"/>
                            </Border>
                        </Grid>

                        <Border x:Name="ScrubberHoverZone"
                                Grid.Row="2"
                                Margin="0,10,0,0"
                                Padding="0,4"
                                Background="#01FFFFFF"
                                Opacity="0.18"
                                Width="560"
                                HorizontalAlignment="Center"
                                Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                MouseEnter="HoverZone_MouseEnter"
                                MouseLeave="HoverZone_MouseLeave">
                            <StackPanel>
                                <TextBlock Text="{Binding PositionText}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                <Slider Style="{StaticResource DarkMediaSliderStyle}"
                                        Minimum="0"
                                        Maximum="{Binding DurationMs, Mode=OneWay}"
                                        Value="{Binding ScrubberPositionMs, Mode=TwoWay}"
                                        IsMoveToPointEnabled="True"
                                        IsEnabled="{Binding HasScrubbableTrack}"
                                        HorizontalAlignment="Stretch"
                                        Loaded="Scrubber_Loaded"
                                        PreviewMouseLeftButtonDown="Scrubber_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="Scrubber_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="Scrubber_LostMouseCapture"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Viewbox>

                <!-- Title overlays the stage background (no dedicated bar) -->
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="12,8,0,0"
                            Panel.ZIndex="30"
                            Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="True">
                        <TextBlock Text="Infinite Jukebox"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForegroundBrush}"/>
                        <TextBlock Text=" by "
                                   FontSize="12"
                                   Margin="6,0,0,3"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                        <TextBlock FontSize="12"
                                   Margin="0,0,0,3"
                                   VerticalAlignment="Bottom">
                            <Hyperlink NavigateUri="https://musicmachinery.com/2012/11/12/the-infinite-jukebox/"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       RequestNavigate="PaulLamereLink_RequestNavigate">
                                Paul Lamere
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- Optional status HUD: dim until hovered, under the title -->
                    <Border x:Name="StatusHoverZone"
                            Margin="0,8,0,0"
                            Padding="8,6"
                            MaxWidth="420"
                            CornerRadius="4"
                            Background="#66000000"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            Opacity="0.15"
                            MouseEnter="HoverZone_MouseEnter"
                            MouseLeave="HoverZone_MouseLeave">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowStatusOverlay}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Grid Height="16" ClipToBounds="True" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Status}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <component:MarqueeTextBlock Text="{Binding NowPlayingMarqueeText}"
                                                            Height="16"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource AppForegroundBrush}">
                                    <component:MarqueeTextBlock.Style>
                                        <Style TargetType="{x:Type component:MarqueeTextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </component:MarqueeTextBlock.Style>
                                </component:MarqueeTextBlock>
                            </Grid>
                            <TextBlock Text="{Binding ElementName=RingView, Path=Ring.HudText}"
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <TextBlock FontSize="10"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}">
                                <Run Text="{Binding RingSegmentCountText, Mode=OneWay}"/>
                                <Run Text="  ·  "/>
                                <Run Text="{Binding JukeboxBranchChanceText, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding AnalysisSourceText}"
                                       FontSize="10"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <TextBlock Text="{Binding DeviceText}"
                                       FontSize="10"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ProgressBar Width="72"
                                             Height="4"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             Maximum="100"
                                             Value="{Binding AnalysisProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsIndeterminateAnalysisProgress, Mode=OneWay}"/>
                                <TextBlock Text="{Binding AnalysisStatusText}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           MaxWidth="280"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppAccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border x:Name="PlayerHostBorder"
                        Width="1" Height="1"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Peek strip / slide-up Controls at the bottom edge -->
        <component:LoopLabBottomPanel Grid.Row="2"
                                      Panel.ZIndex="40"
                                      ActivityLog="{Binding ActivityLog}"
                                      IsExpanded="{Binding IsBottomPanelExpanded, Mode=TwoWay}"
                                      ExpandedHeight="{Binding BottomPanelHeight, Mode=TwoWay}"
                                      Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>
