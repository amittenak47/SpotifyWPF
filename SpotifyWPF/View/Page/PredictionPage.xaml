<UserControl x:Class="SpotifyWPF.View.Page.PredictionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             mc:Ignorable="d"
             DataContext="{Binding PredictionPage, Source={StaticResource Locator}}"
             Loaded="PredictionPage_Loaded"
             Unloaded="PredictionPage_Unloaded"
             d:DesignHeight="450" d:DesignWidth="800"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <DockPanel Margin="8" Background="{DynamicResource AppBackgroundBrush}">
        <StatusBar DockPanel.Dock="Bottom"
                   Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StatusBarItem Width="300">
                <Grid Height="18" ClipToBounds="True">
                    <TextBlock Text="{Binding Status}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <component:MarqueeTextBlock Text="{Binding NowPlayingMarqueeText}"
                                                Height="18"
                                                Foreground="{DynamicResource AppForegroundBrush}">
                        <component:MarqueeTextBlock.Style>
                            <Style TargetType="{x:Type component:MarqueeTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </component:MarqueeTextBlock.Style>
                    </component:MarqueeTextBlock>
                </Grid>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=RingView, Path=Ring.HudText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding RingSegmentCountText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding JukeboxBranchChanceText}"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Label Content="{Binding AnalysisSourceText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="72"
                                 Height="4"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Maximum="100"
                                 Value="{Binding AnalysisProgressPercent, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsIndeterminateAnalysisProgress, Mode=OneWay}"/>
                    <TextBlock Text="{Binding AnalysisStatusText}"
                               VerticalAlignment="Center"
                               MaxWidth="280"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource AppAccentBrush}"/>
                </StackPanel>
                <StatusBarItem.Style>
                    <Style TargetType="StatusBarItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StatusBarItem.Style>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Label Content="{Binding DeviceText}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12"
                        Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Infinite Jukebox"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppForegroundBrush}"/>
                    <TextBlock Text=" by "
                               FontSize="13"
                               Margin="6,0,0,4"
                               VerticalAlignment="Bottom"
                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                    <TextBlock FontSize="13"
                               Margin="0,0,0,4"
                               VerticalAlignment="Bottom">
                        <Hyperlink NavigateUri="https://musicmachinery.com/2012/11/12/the-infinite-jukebox/"
                                   Foreground="{DynamicResource AppAccentBrush}"
                                   RequestNavigate="PaulLamereLink_RequestNavigate">
                            Paul Lamere
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasPlayerInitializationError,
                                                 Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding PlayerInitializationError}"
                                   TextWrapping="Wrap"
                                   Foreground="#E05545"/>
                    </Border>

                    <!-- Main stage: ring fills the black area; search/scrubber/wheel scale with it -->
                    <Border x:Name="StageHost"
                            Grid.Row="2"
                            Margin="0,0,0,8"
                            Background="{DynamicResource AppBackgroundBrush}"
                            ClipToBounds="True"
                            Panel.ZIndex="0"
                            PreviewMouseWheel="StageHost_PreviewMouseWheel">
                        <Grid>
                            <component:FractalBackgroundControl IsActive="{Binding IsFractalBackgroundEnabled}"
                                                                EnergyProvider="{Binding VisualEnergy}"
                                                                Opacity="0.9"
                                                                IsHitTestVisible="False"/>

                            <Viewbox x:Name="StageViewbox"
                                     Stretch="Uniform"
                                     StretchDirection="Both"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Margin="12,4">
                                <Grid x:Name="StageRoot"
                                      Width="560"
                                      Height="742"
                                      RenderTransformOrigin="0.5,0.5"
                                      Background="Transparent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="560"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border x:Name="SearchHoverZone"
                                            Grid.Row="0"
                                            Margin="0,0,0,8"
                                            Padding="0,4"
                                            Background="#01FFFFFF"
                                            Opacity="0.18"
                                            Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            MouseEnter="HoverZone_MouseEnter"
                                            MouseLeave="HoverZone_MouseLeave">
                                        <TextBox x:Name="TrackSearchBox"
                                                 Width="560"
                                                 Text="{Binding TrackInput, UpdateSourceTrigger=PropertyChanged}"
                                                 TextAlignment="Center"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 FontSize="13"
                                                 Padding="8,4"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 CaretBrush="{DynamicResource AppForegroundBrush}"
                                                 Foreground="{DynamicResource AppForegroundBrush}"
                                                 ToolTip="Track ID, URI, or Spotify link — press Enter to play"
                                                 PreviewKeyDown="TrackSearchBox_PreviewKeyDown"/>
                                    </Border>

                                    <component:JukeboxRingView x:Name="RingView"
                                                               Grid.Row="1"
                                                               Width="560"
                                                               Height="560"
                                                               OwnsWheelZoom="False"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               DataContext="{Binding}"/>

                                    <Border x:Name="ScrubberHoverZone"
                                            Grid.Row="2"
                                            Margin="0,10,0,0"
                                            Padding="0,4"
                                            Background="#01FFFFFF"
                                            Opacity="0.18"
                                            Width="560"
                                            HorizontalAlignment="Center"
                                            Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            MouseEnter="HoverZone_MouseEnter"
                                            MouseLeave="HoverZone_MouseLeave">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PositionText}"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,4"
                                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                            <Slider Style="{StaticResource DarkMediaSliderStyle}"
                                                    Minimum="0"
                                                    Maximum="{Binding DurationMs, Mode=OneWay}"
                                                    Value="{Binding ScrubberPositionMs, Mode=TwoWay}"
                                                    IsMoveToPointEnabled="True"
                                                    IsEnabled="{Binding HasScrubbableTrack}"
                                                    HorizontalAlignment="Stretch"
                                                    Loaded="Scrubber_Loaded"
                                                    PreviewMouseLeftButtonDown="Scrubber_PreviewMouseLeftButtonDown"
                                                    PreviewMouseLeftButtonUp="Scrubber_PreviewMouseLeftButtonUp"
                                                    LostMouseCapture="Scrubber_LostMouseCapture"/>
                                        </StackPanel>
                                    </Border>

                                    <component:TransportWheelControl x:Name="TransportWheel"
                                                                     Grid.Row="3"
                                                                     Width="80"
                                                                     Height="80"
                                                                     Margin="0,14,0,4"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     DataContext="{Binding}"
                                                                     Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Viewbox>

                            <Border x:Name="PlayerHostBorder"
                                    Width="1" Height="1"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <component:LoopLabBottomPanel Grid.Row="3"
                                                    Panel.ZIndex="2"
                                                    ActivityLog="{Binding ActivityLog}"
                                                    IsExpanded="{Binding IsBottomPanelExpanded, Mode=TwoWay}"
                                                    ExpandedHeight="{Binding BottomPanelHeight, Mode=TwoWay}"
                                                    Visibility="{Binding IsFullLayout, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </DockPanel>
</UserControl>
