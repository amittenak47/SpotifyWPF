<UserControl x:Class="SpotifyWPF.View.Component.LoopLabBottomPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SpotifyWPF.View.Component"
             xmlns:conv="clr-namespace:SpotifyWPF.Converter"
             x:Name="Root"
             MinHeight="28"
             ClipToBounds="False"
             Background="#01FFFFFF"
             MouseEnter="Root_MouseEnter"
             MouseLeave="Root_MouseLeave">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:SessionPlayGlyphConverter x:Key="SessionPlayGlyphConverter"/>
        <conv:SessionStatusMarqueeConverter x:Key="SessionStatusMarqueeConverter"/>
        <Style x:Key="SessionIconButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1,1,1,0"
            ClipToBounds="False">
        <Grid ClipToBounds="False">
            <DockPanel x:Name="PanelContent" LastChildFill="True">
                <!-- Open/close header (not a resize grip) -->
                <Button x:Name="ExpandToggle"
                        DockPanel.Dock="Top"
                        Cursor="Hand"
                        Focusable="False"
                        Padding="8,6"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1"
                        HorizontalContentAlignment="Stretch"
                        ToolTip="Open/close Controls"
                        Click="ExpandToggle_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HeaderBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Controls"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppForegroundBrush}"/>
                        <TextBlock Margin="8,0,0,0"
                                   FontFamily="Segoe UI Symbol"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▲"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded, ElementName=Root}" Value="True">
                                            <Setter Property="Text" Value="▼"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- Body + resize grip only while open -->
                <Grid Visibility="{Binding IsExpanded, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="ResizeBar"
                            Grid.Row="0"
                            Height="6"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Cursor="SizeNS"
                            ToolTip="Drag to resize"
                            PreviewMouseLeftButtonDown="ResizeBar_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="ResizeBar_PreviewMouseMove"
                            PreviewMouseLeftButtonUp="ResizeBar_PreviewMouseLeftButtonUp">
                        <Border Width="48" Height="3"
                                CornerRadius="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppBorderBrush}"/>
                    </Border>

                    <TabControl Grid.Row="1"
                                Style="{StaticResource ControlPanelTabControlStyle}"
                                DataContext="{Binding DataContext, ElementName=Root}">
                        <TabItem Header="Session">
                            <Border Style="{StaticResource ControlPanelTabContentBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="Preset"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"
                                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                            <ComboBox ItemsSource="{Binding BranchPresets}"
                                                      SelectedItem="{Binding SelectedBranchPreset, Mode=OneWay}"
                                                      DisplayMemberPath="Name"
                                                      Width="120"
                                                      MinHeight="28"
                                                      Margin="0,0,6,0"
                                                      VerticalAlignment="Center"
                                                      ToolTip="Pick an existing preset"
                                                      SelectionChanged="BranchPresetPicker_SelectionChanged"/>
                                            <TextBox Text="{Binding BranchPresetName, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="120"
                                                     MinHeight="28"
                                                     Margin="0,0,6,0"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="Custom preset name"/>
                                            <Button Content="Load"
                                                    MinWidth="52" MinHeight="28" Margin="0,0,4,0"
                                                    Command="{Binding LoadBranchPresetCommand}"
                                                    ToolTip="Load the named tune+branches preset"/>
                                            <Button Content="Save"
                                                    MinWidth="52" MinHeight="28"
                                                    Command="{Binding SaveBranchPresetCommand}"
                                                    ToolTip="Save current tune + locks under the name in the box"/>
                                        </StackPanel>

                                        <Menu Background="Transparent"
                                              VerticalAlignment="Center">
                                            <MenuItem Header="List" Padding="8,4">
                                                <MenuItem Header="Remove"
                                                          Command="{Binding RemoveSessionTrackCommand}"
                                                          ToolTip="Remove the selected track from this list only"/>
                                                <MenuItem Header="Remove all"
                                                          Command="{Binding ClearSessionCommand}"
                                                          ToolTip="Clear the session list only"/>
                                                <MenuItem Header="Refresh from cache"
                                                          Command="{Binding RefreshSessionCommand}"
                                                          ToolTip="Reload the list from audio/analysis caches"/>
                                            </MenuItem>
                                            <MenuItem Header="Delete data" Padding="8,4">
                                                <MenuItem Header="Captures"
                                                          Command="{Binding DeleteSessionCapturesCommand}"
                                                          ToolTip="Delete saved WAV captures for the selected track"/>
                                                <MenuItem Header="Analysis"
                                                          Command="{Binding DeleteSessionAnalysisCommand}"
                                                          ToolTip="Delete saved analysis JSON for the selected track"/>
                                                <MenuItem Header="Tune + branches"
                                                          Command="{Binding DeleteSessionTuneCommand}"
                                                          ToolTip="Delete saved tune settings, locks, and presets"/>
                                            </MenuItem>
                                            <MenuItem Header="Export" Padding="8,4">
                                                <MenuItem Header="Audio…"
                                                          Command="{Binding ExportSessionAudioCommand}"/>
                                                <MenuItem Header="Analysis…"
                                                          Command="{Binding ExportSessionAnalysisCommand}"/>
                                                <MenuItem Header="Both…"
                                                          Command="{Binding ExportSessionBothCommand}"/>
                                            </MenuItem>
                                            <MenuItem Header="Import…"
                                                      Padding="8,4"
                                                      Command="{Binding ImportLoopDataCommand}"
                                                      ToolTip="Import analysis JSON, tune+branches, and/or capture WAV files"/>
                                        </Menu>
                                    </DockPanel>

                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding SessionTracks}"
                                             SelectedItem="{Binding SelectedSessionTrack}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             VerticalAlignment="Stretch"
                                             MinHeight="160"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             MouseDoubleClick="SessionTracks_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="140"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock Text="{Binding Artist}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,6,0">
                                                    <Button Style="{StaticResource SessionIconButtonStyle}"
                                                            Command="{Binding DataContext.PlaySessionTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Play / pause">
                                                        <Button.Content>
                                                            <MultiBinding Converter="{StaticResource SessionPlayGlyphConverter}">
                                                                <Binding Path="."/>
                                                                <Binding Path="DataContext.SessionActiveTrackId"
                                                                         RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                                <Binding Path="DataContext.IsPaused"
                                                                         RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                            </MultiBinding>
                                                        </Button.Content>
                                                    </Button>
                                                    <Button Content="■"
                                                            Style="{StaticResource SessionIconButtonStyle}"
                                                            Margin="0,0,6,0"
                                                            Command="{Binding DataContext.AbortSessionWorkCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            ToolTip="Stop analyze/capture or playback"/>
                                                    <Button Content="Analyze"
                                                            MinWidth="58" MinHeight="26" Padding="6,2"
                                                            FontSize="11"
                                                            Focusable="False"
                                                            Command="{Binding DataContext.AnalyzeSessionTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Capture/analyze this track"/>
                                                </StackPanel>
                                                <ToggleButton Grid.Column="2"
                                                              Margin="0,0,6,0"
                                                              VerticalAlignment="Center"
                                                              MinWidth="36"
                                                              MinHeight="22"
                                                              Padding="4,1"
                                                              FontSize="9"
                                                              IsChecked="{Binding DataContext.UseLocalPlayback, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                              IsEnabled="{Binding HasCapture}"
                                                              PreviewMouseLeftButtonDown="SessionLocalWav_PreviewMouseLeftButtonDown"
                                                              ToolTip="Toggle Local WAV / Spotify">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AppMutedForegroundBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="Bd"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                Padding="{TemplateBinding Padding}"
                                                                                CornerRadius="2"
                                                                                SnapsToDevicePixels="True">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSelectedBrush}"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.4"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Content" Value="SP"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter Property="Content" Value="WAV"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <local:MarqueeTextBlock Grid.Column="3"
                                                                        Height="18"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="10"
                                                                        AlwaysScroll="True"
                                                                        Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                                        ToolTip="{Binding StatusText}">
                                                    <local:MarqueeTextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SessionStatusMarqueeConverter}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.UseLocalPlayback"
                                                                     RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                        </MultiBinding>
                                                    </local:MarqueeTextBlock.Text>
                                                </local:MarqueeTextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </TabItem>

                        <TabItem Header="Tuning">
                            <Border Style="{StaticResource ControlPanelTabContentBorderStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              VerticalAlignment="Stretch"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <Expander Header="Tuning tutorial — how these controls shape hops"
                                                  IsExpanded="False"
                                                  Margin="0,0,0,12"
                                                  Foreground="{DynamicResource AppForegroundBrush}">
                                            <Border Margin="0,8,0,0"
                                                    Padding="10,8"
                                                    Background="#33000000"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="What you are tuning"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="The ring is a weighted beat graph: similar moments become jump targets with continuous distances (not hard same/different buckets). Tuning changes which edges exist, how often random jumps fire, and whether landings stay on musical phase. Sliders rebuild from cached analysis (no re-capture). Session → Analyze for a new track; Delete analysis + Analyze to redo features."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="How this differs from Remixatron-style players"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Playback — Remixatron stitches beat buffers sample-accurately in a native engine (zero seek latency). This app is a WPF authoring player: Spotify Web Playback seeks (±~50ms poll jitter) or Local WAV in-process seeks. That is why seek lead, pre-arming, and one-jump-ahead planning exist here."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Similarity — Remixatron clusters beats once (categorical: same cluster or not) then applies boolean jump rules. Enhanced keeps continuous z-scored distances all the way to Softmax: edges have magnitudes, candidates are kNN + a percentile quality cap, and jump choice is Softmax(−dist/τ − λ·visits + w_pref)."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Continuation — Remixatron requires candidates in the next beat's cluster. Enhanced scores edge i→j by how well beat j continues after i (stacked features of i+1 vs j), so landings fit the exit rather than twinning the same attack (which used to double cymbals)."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Phase — Remixatron hard-requires same position in measure. Enhanced uses BeatThis downbeats when available, plus Soft/Hard/Off bar-phase penalty and optional Phrase align (8/16) for long drum grooves."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Authoring — Remixatron is a fully automatic player. Here you get locks, per-branch probabilities, tune presets bound to analysis fingerprints, ring hover analysis, SSM heatmap, and optional preference labels from scrub-after-hop."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="BeatThis vs legacy DP beats"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="BeatThis is a learned beat/downbeat tracker (robust through quiet gaps that used to create monster beats with librosa's DP tracker). Real downbeats make bar-phase penalties musically honest instead of arbitrary i mod 4. Gap-split remains a safety net if an interval is still much larger than the median."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Settings → Beat tracker: Auto / BeatThis / DP. Graph metric: Auto / Enhanced / Legacy (Legacy = old Echo Nest-style segment distance for old caches)."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="Quick start (smooth Infinite Jukebox)"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="1) Branch quality ~35–50 (lower = only the closest matches). 2) Dwell 12–16 so each hop plays out before another. 3) Bar phase = Soft or Hard. 4) For long drum phrases (Clubbed to Death, Furious Angels) set Phrase align to 8 or 16 and Hard phase. 5) Prefer Local WAV when a capture exists. 6) Keep End loop + Allow random jumps on unless you are authoring locks only."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="Who jumps, and how often"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Branch quality percentile — distance cap for Enhanced edges. Lower = stricter / smoother; higher = more adventurous (and riskier) hops. Rebuilds the graph."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Branch probability min / max — chance range for taking a random hop when a beat has candidates. Min is the floor after a jump; max is the ceiling as chance ramps."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Ramp-up per beat — how fast chance climbs toward max while playing linearly. Higher = more restless."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Dwell after hop — forced linear beats after a jump before another random hop is considered (locks and end-loop still fire). Use ~16 for one phrase of stability."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Allow random jumps — off = only your locked branches (+ end loop if on). On = random walk plus locks at their probabilities."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="Bar / phrase alignment (drums that feel mid-bar)"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="BeatThis places beats and usually 4-beat downbeats. Enhanced similarity can still match a drum hit that is on the grid but not at the same place in an 8- or 16-beat groove — it sounds right on the beat and wrong musically."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Bar phase penalty — Off ignores bar position; Soft prefers same beat-in-bar; Hard only keeps same beat-in-bar edges (rebuilds graph)."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Phrase align — 0 = off. Set 8 or 16 so hops only land on the same phase within that hypermeasure. Pair with Hard phase + dwell 16 for Matrix-style long drum phrases."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="Which edge is chosen"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Softmax temperature τ — lower = greedier nearest match; higher = more random among candidates."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Visit novelty λ — penalizes recently visited beat pockets so the walk explores more of the song."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Preference weight — Slice 6; Softmax adds w_pref·score from pairwise labels (chosen ≻ alternatives; scrub within the skip window after a hop = negative). Does not create new edges. 0 = off."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="Graph topology toggles"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Mutual kNN — keep only reciprocal neighbors (safer components; can orphan unique passages). Bridge components — add cheapest rescue edges so orphans stay reachable (drawn cooler on the ring). Essentia region gate — when embeddings exist, Enhanced hops stay in nearby regions."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Only jump backward / 16+ beats away — navigator filters (long-branch filter does not block the end-loop escape). End loop — guaranteed jump before the track finishes."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Seek lead — fire seeks early to hide Spotify SDK latency. Forced to 0 on Local WAV (in-process seeks need no lead). Enhanced edges are continuation-oriented (land where the next beat would fit), not beat twins."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="When a hop sounds early / late (piano double)"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="If origin plays the final piano notes and the landing starts just before those same notes, the destination is a near-twin of the exit — you hear the cadence twice, slightly offset. Enhanced already scores continuation (i+1 vs j), but phase can still slip."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Try in order: (1) Bar phase = Hard. (2) Phrase align = 8 or 16 on groove tracks. (3) Branch quality lower (stricter). (4) Seek lead = 0 on Local WAV (already forced). (5) Dwell 12–16 so you hear the landing before the next hop. Rebuild the graph after phase/quality changes."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="End loop — escapes the last ~10% of the track and prefers landings before the final fifth so the outro cannot trap you by always jumping to the start of the same ending section. Turn End loop off if you want the song to finish."/>

                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                                               Text="Authoring on the ring"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Hover a beat to preview hops. Press and hold that beat, then drag onto a hop arrow and release to queue it — the origin stays pinned so crossing other beats will not swap the fan. Press+drag another beat to add more. Confirm with the checkmark to lock all queued hops (locked edges show a thin flowing glow). Double-click a locked (gold) branch to remove it. Drag empty coverage / outer rim to scrub. Drag the center gray disc like a dial to set Local WAV speed (double-click dial resets 1×)."/>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                               Text="Save tune + branches from Session (Tune preset) so a settings snapshot + locks stay tied to the analysis fingerprint."/>
                                                </StackPanel>
                                            </Border>
                                        </Expander>

                                        <local:TuningSliderRow Label="Branch quality percentile (lower = stricter / smoother)"
                                                               ValueText="{Binding JukeboxSimilarityThresholdMaxText}"
                                                               Minimum="15"
                                                               Maximum="80"
                                                               Value="{Binding JukeboxSimilarityThresholdMax}"/>
                                        <local:TuningSliderRow Label="Branch probability min"
                                                               ValueText="{Binding JukeboxBranchProbabilityMinText}"
                                                               Minimum="0"
                                                               Maximum="40"
                                                               Value="{Binding JukeboxBranchProbabilityMinPercent}"/>
                                        <local:TuningSliderRow Label="Branch probability max"
                                                               ValueText="{Binding JukeboxBranchProbabilityMaxText}"
                                                               Minimum="5"
                                                               Maximum="60"
                                                               Value="{Binding JukeboxBranchProbabilityMaxPercent}"/>
                                        <local:TuningSliderRow Label="Ramp-up per beat"
                                                               ValueText="{Binding JukeboxBranchRampText}"
                                                               Minimum="0.2"
                                                               Maximum="3"
                                                               Value="{Binding JukeboxBranchRampPerBeatPercent}"/>
                                        <local:TuningSliderRow Label="Seek lead (Spotify SDK only; 0 on Local WAV)"
                                                               ValueText="{Binding JukeboxSeekLeadMsText}"
                                                               Minimum="0"
                                                               Maximum="300"
                                                               Value="{Binding JukeboxSeekLeadMs}"/>
                                        <local:TuningSliderRow Label="Dwell after hop (linear beats before next random hop)"
                                                               ValueText="{Binding JukeboxMinBeatsBetweenJumpsText}"
                                                               Minimum="0"
                                                               Maximum="64"
                                                               Value="{Binding JukeboxMinBeatsBetweenJumps}"/>
                                        <local:TuningSliderRow Label="Phrase align (beats; 0=off — use 8/16 for long drum phrases)"
                                                               ValueText="{Binding JukeboxPhraseAlignBeatsText}"
                                                               Minimum="0"
                                                               Maximum="32"
                                                               Value="{Binding JukeboxPhraseAlignBeats}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Bar phase penalty"
                                                       Width="160"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AppForegroundBrush}"
                                                       ToolTip="Hard = only hop to the same beat-in-bar. Soft = prefer same phase. Off = ignore bar phase. Helps Furious Angels / Clubbed to Death-style long drum phrases when paired with Phrase align."/>
                                            <ComboBox MinWidth="120"
                                                      MinHeight="28"
                                                      VerticalAlignment="Center"
                                                      ItemsSource="{Binding PhasePenaltyModeOptions}"
                                                      SelectedItem="{Binding SelectedPhasePenaltyMode}"/>
                                        </StackPanel>
                                        <local:TuningSliderRow Label="Softmax temperature τ (lower = greedier)"
                                                               ValueText="{Binding JukeboxSoftmaxTemperatureText}"
                                                               Minimum="0.1"
                                                               Maximum="4"
                                                               Value="{Binding JukeboxSoftmaxTemperature}"/>
                                        <local:TuningSliderRow Label="Visit novelty λ (penalize revisited pockets)"
                                                               ValueText="{Binding JukeboxVisitNoveltyLambdaText}"
                                                               Minimum="0"
                                                               Maximum="2"
                                                               Value="{Binding JukeboxVisitNoveltyLambda}"/>
                                        <local:TuningSliderRow Label="Preference weight w_pref (Slice 6 rerank)"
                                                               ValueText="{Binding JukeboxPreferenceWeightText}"
                                                               Minimum="0"
                                                               Maximum="50"
                                                               Value="{Binding JukeboxPreferenceWeightPercent}"/>
                                        <local:TuningSliderRow Label="Preference skip window (scrub after hop = negative)"
                                                               ValueText="{Binding JukeboxPreferenceSkipWindowText}"
                                                               Minimum="1"
                                                               Maximum="20"
                                                               Value="{Binding JukeboxPreferenceSkipWindowSeconds}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="Clear preferences" MinWidth="120"
                                                    Command="{Binding ClearBranchPreferencesCommand}"
                                                    ToolTip="Wipe pairwise branch preference labels (branch-preferences.json)."/>
                                            <TextBlock Text="{Binding BranchPreferenceStatusText}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0"
                                                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                        </StackPanel>

                                        <CheckBox Content="Only jump backward (earlier in the song)"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxAllowOnlyReverseBranches}"
                                                  Margin="0,0,0,4"
                                                  ToolTip="Blocks forward jumps. Extends earlier sections, but hurts novelty — you keep revisiting the same earlier material."/>
                                        <CheckBox Content="Only jump 16+ beats away"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxAllowOnlyLongBranches}"
                                                  Margin="0,0,0,4"
                                                  ToolTip="Skips short local echoes. Does not block the end-loop escape jump."/>
                                        <CheckBox Content="Mutual kNN graph (Slice 4)"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxUseMutualKnn}"
                                                  Margin="0,0,0,4"
                                                  ToolTip="Keep only reciprocal neighbors. Rebuilds the beat graph."/>
                                        <CheckBox Content="Bridge disconnected components"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxEnableSccBridges}"
                                                  Margin="0,0,0,4"
                                                  ToolTip="After mutual-kNN, add cheapest bridges so unique passages stay reachable. Drawn cooler on the ring."/>
                                        <CheckBox Content="Essentia region gate (needs embeddings)"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxEssentiaRegionGate}"
                                                  Margin="0,0,0,4"
                                                  ToolTip="When analysis has regionEmbeddings, Enhanced hops are gated to nearby regions. Rebuilds graph."/>
                                        <CheckBox Content="Never let the song finish (end loop)"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxEnableEndLoop}"
                                                  Margin="0,0,0,4"
                                                  ToolTip="Forces a jump back before the track ends. Also recovers if a hop lands past the last escape beat."/>
                                        <CheckBox Content="Allow random jumps"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding JukeboxRandomBranches}"
                                                  Margin="0,0,0,8"
                                                  ToolTip="On: random walk plus your locked branches. Off: only locked branches (and end loop if enabled)."/>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Clear locks" MinWidth="88"
                                                    Command="{Binding ClearRingLocksCommand}"/>
                                            <Button Content="Reset plays" MinWidth="88" Margin="8,0,0,0"
                                                    Command="{Binding ResetRingPlaysCommand}"
                                                    ToolTip="Clear the ring's play-coverage bars"/>
                                            <TextBlock Text="{Binding RingLockCountText}"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0,0,0"
                                                       Foreground="#FFD166"/>
                                        </StackPanel>

                                        <local:TuningSliderRow Label="Branch preview hops"
                                                               ValueText="{Binding RingPreviewHopDepth, StringFormat={}{0:0}}"
                                                               Minimum="1"
                                                               Maximum="3"
                                                               Value="{Binding RingPreviewHopDepth}"
                                                               Margin="0,8,0,0"/>

                                        <CheckBox Content="Show similarity map (SSM)"
                                                  Foreground="{DynamicResource AppForegroundBrush}"
                                                  IsChecked="{Binding ShowSsmHeatmap}"
                                                  Margin="0,0,0,8"
                                                  ToolTip="Beats×beats self-similarity overlay on the ring. Bright stripes = repeats; click a row to inspect that beat."/>

                                        <TextBlock Text="Sliders rebuild the beat graph from cached analysis (no re-capture). Use Session Analyze for a new track; Delete cache + Analyze to re-capture audio."
                                                   FontSize="11"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                        <TextBlock Text="press a beat + drag to a hop — release to queue — ✓ confirms locks · SSM = full similarity map (draggable)"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </TabItem>

                        <TabItem Header="Prediction">
                            <Border Style="{StaticResource ControlPanelTabContentBorderStyle}">
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <Button DockPanel.Dock="Right" Content="Refresh" MinWidth="80"
                                            Command="{Binding RefreshPredictionsCommand}"/>
                                    <CheckBox DockPanel.Dock="Right" Content="Auto-play next"
                                              Margin="0,0,12,0" VerticalAlignment="Center"
                                              Foreground="{DynamicResource AppForegroundBrush}"
                                              IsChecked="{Binding AutoPlayNext}"
                                              ToolTip="When a track ends naturally (jukebox off), start the top prediction"/>
                                    <TextBlock Text="{Binding PredictionStatusText}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                </DockPanel>

                                <ListBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                         ItemsSource="{Binding Predictions}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         VerticalAlignment="Stretch"
                                         MinHeight="72"
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                    <TextBlock Text="{Binding Reason}" FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Score, StringFormat={}{0:0.00}}"
                                                           VerticalAlignment="Center" Margin="8,0"
                                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                                <Button Grid.Column="2" Content="Play" MinWidth="56" Margin="0,0,6,0"
                                                        Command="{Binding DataContext.PlayPredictionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Grid.Column="3"
                                                        MinWidth="56"
                                                        Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Content" Value="Pin"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Content" Value="Unpin"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1">
                                    <TextBlock Text="Scoring weights"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"
                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                    <local:TuningSliderRow Label="Recency penalty"
                                                           ValueText="{Binding WeightRecencyPenalty, StringFormat={}{0:0.00}}"
                                                           Minimum="0"
                                                           Maximum="2"
                                                           Value="{Binding WeightRecencyPenalty}"/>
                                    <local:TuningSliderRow Label="Pinned bonus"
                                                           ValueText="{Binding WeightPinned, StringFormat={}{0:0.00}}"
                                                           Minimum="0"
                                                           Maximum="5"
                                                           Value="{Binding WeightPinned}"/>
                                </StackPanel>
                                </Grid>
                            </Border>
                        </TabItem>

                        <TabItem Header="Log">
                            <Border Style="{StaticResource ControlPanelTabContentBorderStyle}">
                                <local:ActivityLogView DataContext="{Binding ActivityLog, ElementName=Root}"
                                                       VerticalAlignment="Stretch"/>
                            </Border>
                        </TabItem>

                        <TabItem Header="Settings">
                            <Border Style="{StaticResource ControlPanelTabContentBorderStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              VerticalAlignment="Stretch"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel MaxWidth="640">
                                    <TextBlock Text="Local analysis (Path B)"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppForegroundBrush}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}">
                                        Configure the Python interpreter used for librosa-based beat analysis when Spotify's audio-analysis API is unavailable.
                                    </TextBlock>

                                    <TextBlock Text="Python executable" Margin="0,0,0,4"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding PythonExecutablePath, UpdateSourceTrigger=LostFocus}"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Full path to python.exe; leave empty to auto-detect on first analysis"/>
                                        <Button Grid.Column="1" Content="Browse" MinWidth="72" Margin="8,0,0,0"
                                                Command="{Binding BrowsePythonCommand}"/>
                                        <Button Grid.Column="2" Content="Auto-detect" MinWidth="88" Margin="8,0,0,0"
                                                Command="{Binding AutoDetectPythonCommand}"/>
                                    </Grid>

                                    <Button Content="Re-probe analysis source"
                                            HorizontalAlignment="Left"
                                            MinWidth="160"
                                            Command="{Binding ReprobeAnalysisCommand}"
                                            ToolTip="Check whether Spotify API or local Python analysis is available"/>

                                    <TextBlock Text="Jukebox analysis"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppForegroundBrush}"
                                               Margin="0,16,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}">
                                        Beat tracker applies on the next Analyze (delete cache first to re-run). Graph metric rebuilds immediately from the current analysis JSON.
                                    </TextBlock>

                                    <TextBlock Text="Beat tracker" Margin="0,0,0,4"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                    <ComboBox Margin="0,0,0,12" MinWidth="220" HorizontalAlignment="Left"
                                              ItemsSource="{Binding BeatTrackerModeOptions}"
                                              SelectedItem="{Binding SelectedBeatTrackerMode}"
                                              ToolTip="Auto: BeatThis if installed, else DP. BeatThis: require package/ONNX. DP: force librosa."/>

                                    <TextBlock Text="Graph metric" Margin="0,0,0,4"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                    <ComboBox Margin="0,0,0,12" MinWidth="220" HorizontalAlignment="Left"
                                              ItemsSource="{Binding GraphMetricModeOptions}"
                                              SelectedItem="{Binding SelectedGraphMetricMode}"
                                              ToolTip="Auto: Enhanced when stackedFeatures exist. Enhanced = continuation-oriented beat vectors; Legacy = old Echo Nest segment distance."/>

                                    <TextBlock Text="Window"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppForegroundBrush}"
                                               Margin="0,16,0,8"/>
                                    <CheckBox Content="Ring mini player mode"
                                              Foreground="{DynamicResource AppForegroundBrush}"
                                              IsChecked="{Binding IsMiniPlayerMode, Mode=TwoWay}"
                                              ToolTip="Show only the jukebox ring in a compact window (use Minimize on the transport wheel to enter)"
                                              Margin="0,0,0,4"/>
                                    <CheckBox Content="Fractal background"
                                              Foreground="{DynamicResource AppForegroundBrush}"
                                              IsChecked="{Binding IsFractalBackgroundEnabled}"
                                              ToolTip="Fractal background synced to the equalizer"
                                              Margin="0,0,0,4"/>
                                    <TextBlock Text="Equalizer"
                                               Margin="0,8,0,4"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                                    <ComboBox Margin="0,0,0,8" MinWidth="220" HorizontalAlignment="Left"
                                              ItemsSource="{Binding EqualizerPresetOptions}"
                                              SelectedItem="{Binding SelectedEqualizerPreset}"
                                              ToolTip="Cascading bars = classic Winamp segments. Wave ring = soft spectrum envelope + cyan ticks."/>
                                    <CheckBox Content="Show status overlay"
                                              Foreground="{DynamicResource AppForegroundBrush}"
                                              IsChecked="{Binding ShowStatusOverlay}"
                                              ToolTip="When enabled, hover under the title to reveal now-playing and analysis status"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </DockPanel>

            <Canvas x:Name="ResizePreviewCanvas"
                    ClipToBounds="False"
                    IsHitTestVisible="False"
                    Panel.ZIndex="20">
                <Border x:Name="ResizePreviewGhost"
                        Background="#CC121212"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16"
                                          ShadowDepth="4"
                                          Opacity="0.65"
                                          Color="Black"/>
                    </Border.Effect>
                </Border>
            </Canvas>
        </Grid>
    </Border>
</UserControl>
