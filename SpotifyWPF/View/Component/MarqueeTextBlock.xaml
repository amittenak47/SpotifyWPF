<UserControl x:Class="SpotifyWPF.View.Component.MarqueeTextBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             ClipToBounds="True">

    <Grid x:Name="HostGrid">
        <TextBlock x:Name="MeasureText"
                   Text="{Binding Text, ElementName=Root}"
                   Visibility="Collapsed"
                   FontSize="{Binding FontSize, ElementName=Root}"
                   FontWeight="{Binding FontWeight, ElementName=Root}"/>

        <Canvas x:Name="MarqueeCanvas" Height="{Binding ActualHeight, ElementName=HostGrid}">
            <TextBlock x:Name="ScrollText"
                       Text="{Binding Text, ElementName=Root}"
                       Foreground="{Binding Foreground, ElementName=Root}"
                       FontSize="{Binding FontSize, ElementName=Root}"
                       FontWeight="{Binding FontWeight, ElementName=Root}"
                       Canvas.Top="0">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="ScrollTransform" X="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>
    </Grid>
</UserControl>
