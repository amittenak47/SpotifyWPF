<UserControl x:Class="SpotifyWPF.View.Component.LoopLabLibrarySidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             ClipToBounds="True">
    <Border Background="Transparent"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="0,0,10,0">
        <DockPanel LastChildFill="True">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10" LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="&#xE72C;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="28"
                        Height="28"
                        Padding="0"
                        FontSize="12"
                        Focusable="False"
                        ToolTip="Refresh playlists"
                        Command="{Binding RefreshLibraryPlaylistsCommand}"/>
                <TextBlock Text="Library"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}"/>
            </DockPanel>

            <TextBlock DockPanel.Dock="Top"
                       Text="Cached playlists from Manage"
                       FontSize="11"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource AppMutedForegroundBrush}"/>

            <TextBlock DockPanel.Dock="Top"
                       Text="No playlists yet — load some in Manage."
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       Opacity="0.7"
                       Foreground="{DynamicResource AppMutedForegroundBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasLibraryPlaylists}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ListBox ItemsSource="{Binding LibraryPlaylists}"
                     SelectedItem="{Binding SelectedLibraryPlaylist, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="LibraryList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="2,5" LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="&#xE710;"
                                    FontFamily="Segoe MDL2 Assets"
                                    MinWidth="28"
                                    MinHeight="26"
                                    Padding="4,2"
                                    Margin="8,0,0,0"
                                    FontSize="12"
                                    Focusable="False"
                                    ToolTip="Add playlist tracks to Session"
                                    Command="{Binding DataContext.AddLibraryPlaylistToSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                                <TextBlock Text="{Binding TracksTotal, StringFormat={}{0} tracks}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
