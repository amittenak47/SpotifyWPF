<UserControl x:Class="SpotifyWPF.View.Component.TuningSliderRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <StackPanel Margin="0,0,0,14">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       Foreground="{DynamicResource AppMutedForegroundBrush}"
                       VerticalAlignment="Center"/>
            <Border Style="{StaticResource SettingValueBadgeStyle}">
                <TextBlock Text="{Binding ValueText, ElementName=Root}"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           FontFamily="Consolas"
                           FontSize="11"/>
            </Border>
        </StackPanel>

        <Slider x:Name="ValueSlider"
                Style="{StaticResource DarkMediaSliderStyle}"
                Minimum="{Binding Minimum, ElementName=Root}"
                Maximum="{Binding Maximum, ElementName=Root}"
                Value="{Binding Value, ElementName=Root, Mode=TwoWay}"/>
    </StackPanel>
</UserControl>
