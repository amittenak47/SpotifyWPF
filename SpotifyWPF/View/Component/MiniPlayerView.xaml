<UserControl x:Class="SpotifyWPF.View.Component.MiniPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             Background="{x:Null}">

    <UserControl.Resources>
        <Style x:Key="TransportIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniPlayerChromeButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TransportIconButtonStyle}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="TransportGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{x:Null}">
        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">
            <component:JukeboxRingView Width="380" Height="380"
                                         DataContext="{Binding}"
                                         MiniPlayerMode="True"/>
        </Viewbox>

        <Border x:Name="ControlsBackdrop"
                Panel.ZIndex="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="6,5"
                Cursor="Arrow"
                RenderTransformOrigin="0.5,0.5"
                PreviewMouseLeftButtonDown="ControlsBackdrop_PreviewMouseLeftButtonDown">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.78" ScaleY="0.78"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6"
                                  ShadowDepth="1"
                                  Opacity="0.35"
                                  Color="Black"/>
            </Border.Effect>
            <StackPanel MinWidth="132">
                <Button Style="{StaticResource MiniPlayerChromeButtonStyle}"
                        HorizontalAlignment="Left"
                        Command="{Binding ExitMiniPlayerCommand}">
                    <TextBlock Text="&#xE918;" Style="{StaticResource TransportGlyphStyle}" FontSize="10"/>
                </Button>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0">
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Width="36" Height="36"
                            Command="{Binding PreviousSessionTrackCommand}">
                        <TextBlock Text="&#xE892;" Style="{StaticResource TransportGlyphStyle}" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Width="42" Height="42"
                            Margin="6,0"
                            Command="{Binding TogglePlayPauseCommand}">
                        <TextBlock FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TransportGlyphStyle}">
                                    <Setter Property="Text" Value="&#xE768;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPauseIcon}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Width="34" Height="34"
                            Margin="4,0"
                            Command="{Binding StopPlaybackCommand}">
                        <TextBlock Text="&#xE71A;" Style="{StaticResource TransportGlyphStyle}" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Width="36" Height="36"
                            Command="{Binding NextSessionTrackCommand}">
                        <TextBlock Text="&#xE893;" Style="{StaticResource TransportGlyphStyle}" FontSize="14"/>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,5,0,0">
                    <CheckBox Content="Locks only"
                              VerticalAlignment="Center"
                              FontSize="10"
                              Foreground="{DynamicResource AppForegroundBrush}"
                              IsChecked="{Binding JukeboxLocksOnly}"/>
                    <TextBlock Text="{Binding RingLockCountText}"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Margin="8,0,0,0"
                               Foreground="#FFD166"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0">
                    <Button Content="Clear locks" MinWidth="56" Height="20"
                            FontSize="10" Padding="4,0"
                            Command="{Binding ClearRingLocksCommand}"/>
                    <Button Content="Reset plays" MinWidth="56" Height="20" Margin="6,0,0,0"
                            FontSize="10" Padding="4,0"
                            Command="{Binding ResetRingPlaysCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
