<UserControl x:Class="SpotifyWPF.View.Component.MiniPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{x:Null}">

    <UserControl.Resources>
        <Style x:Key="MiniPlayerWheelButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="#01FFFFFF">
                            <Border x:Name="Border"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="#22000000"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    SnapsToDevicePixels="True"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,0.5,0,0"
                                              IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniPlayerLockToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="#01FFFFFF">
                            <Border x:Name="Border"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="#22000000"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    SnapsToDevicePixels="True"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,0.5,0,0"
                                              IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFD166"/>
                                <Setter TargetName="Border" Property="Background" Value="#33FFD166"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <Style x:Key="WheelSliceIconStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <PathGeometry x:Key="WheelNorthWestWedge" Figures="M 16.54,67.46 A 36,36 0 0,1 16.54,16.54 L 31.39,31.39 A 15,15 0 0,0 31.39,52.61 Z"/>
        <PathGeometry x:Key="WheelNorthEastWedge" Figures="M 16.54,16.54 A 36,36 0 0,1 67.46,16.54 L 52.61,31.39 A 15,15 0 0,0 31.39,31.39 Z"/>
        <PathGeometry x:Key="WheelSouthEastWedge" Figures="M 67.46,16.54 A 36,36 0 0,1 67.46,67.46 L 52.61,52.61 A 15,15 0 0,0 52.61,31.39 Z"/>
        <PathGeometry x:Key="WheelSouthWestWedge" Figures="M 67.46,67.46 A 36,36 0 0,1 16.54,67.46 L 31.39,52.61 A 15,15 0 0,0 52.61,52.61 Z"/>
        <PathGeometry x:Key="WheelWestHalf" Figures="M 42,78 A 36,36 0 0,1 42,6 L 42,27 A 15,15 0 0,0 42,57 Z"/>
        <PathGeometry x:Key="WheelEastHalf" Figures="M 42,6 A 36,36 0 0,1 42,78 L 42,57 A 15,15 0 0,0 42,27 Z"/>
    </UserControl.Resources>

    <Grid x:Name="DragRoot"
          Background="#01FFFFFF"
          PreviewMouseLeftButtonDown="DragRoot_PreviewMouseLeftButtonDown"
          PreviewMouseMove="DragRoot_PreviewMouseMove"
          PreviewMouseLeftButtonUp="DragRoot_PreviewMouseLeftButtonUp"
          PreviewMouseWheel="DragRoot_PreviewMouseWheel"
          LostMouseCapture="DragRoot_LostMouseCapture">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Height="14"
              Margin="40,16,40,0"
              HorizontalAlignment="Stretch"
              ClipToBounds="True"
              IsHitTestVisible="False">
            <TextBlock Text="Nothing playing"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="9"
                       Foreground="{DynamicResource AppMutedForegroundBrush}">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <component:MarqueeTextBlock Text="{Binding NowPlayingMarqueeText}"
                                        Height="14"
                                        FontSize="9"
                                        AlwaysScroll="False"
                                        HorizontalAlignment="Stretch"
                                        Foreground="{DynamicResource AppForegroundBrush}">
                <component:MarqueeTextBlock.Style>
                    <Style TargetType="{x:Type component:MarqueeTextBlock}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </component:MarqueeTextBlock.Style>
            </component:MarqueeTextBlock>
        </Grid>

        <Border Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Padding="16,8,16,20"
                Background="Transparent">
            <Viewbox Stretch="Uniform"
                     StretchDirection="Both"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Grid Width="240" Height="240" Background="Transparent">
                    <Grid x:Name="RingHostGrid" Background="Transparent">
                        <Border x:Name="RingDragPad"
                                Background="#01FFFFFF"
                                Panel.ZIndex="0"
                                PreviewMouseLeftButtonDown="RingDragPad_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="RingDragPad_PreviewMouseMove"
                                PreviewMouseLeftButtonUp="RingDragPad_PreviewMouseLeftButtonUp"/>
                        <Viewbox x:Name="RingViewHost"
                                 Stretch="Uniform"
                                 Panel.ZIndex="1"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch">
                            <component:JukeboxRingView x:Name="RingView"
                                                       Width="240" Height="240"
                                                       DataContext="{Binding}"
                                                       MiniPlayerMode="True"/>
                        </Viewbox>
                    </Grid>

                    <!-- Wheels overlay the lower ring so bottom padding cannot clip them. -->
                    <Viewbox Width="48" Height="48"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,4"
                             Panel.ZIndex="3">
                        <Grid Width="84" Height="84">
                            <Canvas x:Name="LockWheelOverlay"
                                    Width="84"
                                    Height="84"
                                    Opacity="0"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <Ellipse Width="80" Height="80"
                                         Canvas.Left="2" Canvas.Top="2"
                                         Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="1.5"
                                         IsHitTestVisible="False"/>
                                <Line X1="12" Y1="12" X2="72" Y2="72" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
                                <Line X1="72" Y1="12" X2="12" Y2="72" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>

                                <Path x:Name="LockWheelClearArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelNorthWestWedge}" IsHitTestVisible="False"/>
                                <Path x:Name="LockWheelMaximizeArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelNorthEastWedge}" IsHitTestVisible="False"/>
                                <Path x:Name="LockWheelResetArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelSouthEastWedge}" IsHitTestVisible="False"/>
                                <Path x:Name="LockWheelHopsArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelSouthWestWedge}" IsHitTestVisible="False"/>

                                <TextBlock x:Name="LockWheelClearLabel" Text="&#xE74D;" ToolTip="Clear"
                                           Style="{StaticResource WheelSliceIconStyle}"
                                           Canvas.Left="8" Canvas.Top="34"/>
                                <TextBlock x:Name="LockWheelMaximizeLabel" Text="&#xE923;" ToolTip="Restore"
                                           Style="{StaticResource WheelSliceIconStyle}"
                                           Canvas.Left="34" Canvas.Top="8"/>
                                <TextBlock x:Name="LockWheelResetLabel" Text="&#xE72C;" ToolTip="Reset"
                                           Style="{StaticResource WheelSliceIconStyle}"
                                           Canvas.Left="60" Canvas.Top="34"/>
                                <TextBlock x:Name="LockWheelHopsLabel" Text="&#xE8B1;" ToolTip="Hops"
                                           Style="{StaticResource WheelSliceIconStyle}"
                                           Canvas.Left="34" Canvas.Top="60"/>
                            </Canvas>

                            <ToggleButton x:Name="LockToggle"
                                          Style="{StaticResource MiniPlayerLockToggleStyle}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ToolTip="Tap: locks only · Drag: wheel"
                                          IsChecked="{Binding JukeboxLocksOnly}"
                                          PreviewMouseLeftButtonDown="LockToggle_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="LockToggle_PreviewMouseMove"
                                          PreviewMouseLeftButtonUp="LockToggle_PreviewMouseLeftButtonUp">
                                <TextBlock Text="&#xE72E;" Style="{StaticResource TransportGlyphStyle}" FontSize="10"/>
                            </ToggleButton>
                        </Grid>
                    </Viewbox>

                    <Viewbox Width="48" Height="48"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,4"
                             Panel.ZIndex="3">
                    <Grid Width="84" Height="84">
                        <Canvas x:Name="TransportWheelOverlay"
                                Width="84"
                                Height="84"
                                Opacity="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <Ellipse Width="80" Height="80"
                                     Canvas.Left="2" Canvas.Top="2"
                                     Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="1.5"
                                     IsHitTestVisible="False"/>
                            <Line X1="8" Y1="42" X2="26" Y2="42" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
                            <Line X1="58" Y1="42" X2="76" Y2="42" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>

                            <Path x:Name="TransportWheelPrevArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelWestHalf}" IsHitTestVisible="False"/>
                            <Path x:Name="TransportWheelNextArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelEastHalf}" IsHitTestVisible="False"/>

                            <TextBlock x:Name="TransportWheelPrevLabel" Text="&#xE892;" ToolTip="Previous"
                                       Style="{StaticResource WheelSliceIconStyle}"
                                       Canvas.Left="8" Canvas.Top="34"/>
                            <TextBlock x:Name="TransportWheelNextLabel" Text="&#xE893;" ToolTip="Next"
                                       Style="{StaticResource WheelSliceIconStyle}"
                                       Canvas.Left="60" Canvas.Top="34"/>
                        </Canvas>

                        <Button x:Name="TransportButton"
                                Style="{StaticResource MiniPlayerWheelButtonStyle}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ToolTip="Tap: play/pause · Drag: prev / next"
                                PreviewMouseLeftButtonDown="TransportButton_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="TransportButton_PreviewMouseMove"
                                PreviewMouseLeftButtonUp="TransportButton_PreviewMouseLeftButtonUp">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TransportGlyphStyle}">
                                        <Setter Property="Text" Value="&#xE768;"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowPauseIcon}" Value="True">
                                                <Setter Property="Text" Value="&#xE769;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                    </Viewbox>
                </Grid>
            </Viewbox>
        </Border>

        <!-- Lock count lives on the outer chrome, not inside the ring/wheel composition. -->
        <StackPanel Grid.Row="0"
                    Grid.RowSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="12,0,0,10"
                    IsHitTestVisible="False">
            <TextBlock Text="{Binding RingLockCount}" FontSize="10" Foreground="#FFD166"/>
            <Ellipse x:Name="HopModeIndicator" Width="6" Height="6" Margin="4,0,0,0" VerticalAlignment="Center" Fill="#FFD166" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</UserControl>
