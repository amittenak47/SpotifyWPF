<UserControl x:Class="SpotifyWPF.View.Component.MiniPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             Background="{x:Null}">

    <UserControl.Resources>
        <Style x:Key="TransportIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniPlayerLockToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFD166"/>
                                <Setter TargetName="Border" Property="Background" Value="#33FFD166"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniPlayerChromeButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TransportIconButtonStyle}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="MiniPlayerFooterButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <Style x:Key="TransportGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{x:Null}">
        <!-- Same fractal layer as PredictionPage; feathered out over the transparent center disc
             so the transport backdrop and window drag behavior stay untouched. -->
        <component:FractalBackgroundControl IsActive="{Binding IsFractalBackgroundEnabled}"
                                            EnergyProvider="{Binding VisualEnergy}"
                                            MiniPlayerMode="True"
                                            Opacity="0.9"
                                            IsHitTestVisible="False"/>
        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">
            <component:JukeboxRingView Width="380" Height="380"
                                         DataContext="{Binding}"
                                         MiniPlayerMode="True"/>
        </Viewbox>

        <Border x:Name="ControlsBackdrop"
                Panel.ZIndex="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#66141414"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,6"
                Cursor="Arrow"
                MinWidth="148"
                RenderTransformOrigin="0.5,0.5"
                PreviewMouseLeftButtonDown="ControlsBackdrop_PreviewMouseLeftButtonDown">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.88" ScaleY="0.88"/>
            </Border.RenderTransform>
            <Grid Width="156" Height="92">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                    <ToggleButton Style="{StaticResource MiniPlayerLockToggleStyle}"
                                  Content="🔒"
                                  ToolTip="Locks only"
                                  IsChecked="{Binding JukeboxLocksOnly}"/>
                    <TextBlock Text="{Binding RingLockCount}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               FontSize="10"
                               Foreground="#FFD166"/>
                </StackPanel>

                <Button Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource MiniPlayerChromeButtonStyle}"
                        Command="{Binding ExitMiniPlayerCommand}"
                        ToolTip="Restore window">
                    <TextBlock Text="&#xE922;" Style="{StaticResource TransportGlyphStyle}" FontSize="9"/>
                </Button>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Command="{Binding PreviousSessionTrackCommand}">
                        <TextBlock Text="&#xE892;" Style="{StaticResource TransportGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Width="34" Height="34"
                            Margin="5,0"
                            Command="{Binding TogglePlayPauseCommand}">
                        <TextBlock FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TransportGlyphStyle}">
                                    <Setter Property="Text" Value="&#xE768;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPauseIcon}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Command="{Binding StopPlaybackCommand}">
                        <TextBlock Text="&#xE71A;" Style="{StaticResource TransportGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Command="{Binding NextSessionTrackCommand}">
                        <TextBlock Text="&#xE893;" Style="{StaticResource TransportGlyphStyle}"/>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="2" VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource MiniPlayerFooterButtonStyle}"
                            HorizontalAlignment="Left"
                            Content="Clear"
                            Command="{Binding ClearRingLocksCommand}"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource MiniPlayerFooterButtonStyle}"
                            HorizontalAlignment="Right"
                            Content="Reset"
                            Command="{Binding ResetRingPlaysCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
