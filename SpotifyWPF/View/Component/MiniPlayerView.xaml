<UserControl x:Class="SpotifyWPF.View.Component.MiniPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             Background="{x:Null}">

    <UserControl.Resources>
        <Style x:Key="TransportIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniPlayerChromeButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TransportIconButtonStyle}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="MiniPlayerFooterButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <Style x:Key="TransportGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{x:Null}">
        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">
            <component:JukeboxRingView Width="380" Height="380"
                                         DataContext="{Binding}"
                                         MiniPlayerMode="True"/>
        </Viewbox>

        <Border x:Name="ControlsBackdrop"
                Panel.ZIndex="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#66141414"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="5,4"
                Cursor="Arrow"
                MinWidth="108"
                RenderTransformOrigin="0.5,0.5"
                PreviewMouseLeftButtonDown="ControlsBackdrop_PreviewMouseLeftButtonDown">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.62" ScaleY="0.62"/>
            </Border.RenderTransform>
            <Grid Width="132" Height="72">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <CheckBox Grid.Row="0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Content="🔒"
                          ToolTip="Locks only"
                          FontSize="11"
                          Padding="0"
                          Margin="0"
                          Foreground="{DynamicResource AppForegroundBrush}"
                          IsChecked="{Binding JukeboxLocksOnly}"/>

                <Button Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource MiniPlayerChromeButtonStyle}"
                        Command="{Binding ExitMiniPlayerCommand}"
                        ToolTip="Restore window">
                    <TextBlock Text="&#xE922;" Style="{StaticResource TransportGlyphStyle}" FontSize="9"/>
                </Button>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Command="{Binding PreviousSessionTrackCommand}">
                        <TextBlock Text="&#xE892;" Style="{StaticResource TransportGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Width="28" Height="28"
                            Margin="4,0"
                            Command="{Binding TogglePlayPauseCommand}">
                        <TextBlock FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TransportGlyphStyle}">
                                    <Setter Property="Text" Value="&#xE768;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPauseIcon}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Command="{Binding StopPlaybackCommand}">
                        <TextBlock Text="&#xE71A;" Style="{StaticResource TransportGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TransportIconButtonStyle}"
                            Command="{Binding NextSessionTrackCommand}">
                        <TextBlock Text="&#xE893;" Style="{StaticResource TransportGlyphStyle}"/>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="2" VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource MiniPlayerFooterButtonStyle}"
                            HorizontalAlignment="Left"
                            Command="{Binding ClearRingLocksCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Clear" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding RingLockCount}"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FFD166"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1"
                            Style="{StaticResource MiniPlayerFooterButtonStyle}"
                            HorizontalAlignment="Right"
                            Content="Reset"
                            Command="{Binding ResetRingPlaysCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
