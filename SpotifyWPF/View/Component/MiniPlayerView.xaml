<UserControl x:Class="SpotifyWPF.View.Component.MiniPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:component="clr-namespace:SpotifyWPF.View.Component"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{x:Null}">

    <UserControl.Resources>
        <Style x:Key="MiniPlayerWheelButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="#01FFFFFF">
                            <Border x:Name="Border"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="#01FFFFFF"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    SnapsToDevicePixels="True"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniPlayerLockToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="#01FFFFFF">
                            <Border x:Name="Border"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="#01FFFFFF"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    SnapsToDevicePixels="True"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFD166"/>
                                <Setter TargetName="Border" Property="Background" Value="#33FFD166"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <PathGeometry x:Key="WheelTopWedge" Figures="M 16.54,16.54 A 36,36 0 0,1 67.46,16.54 L 52.61,31.39 A 15,15 0 0,0 31.39,31.39 Z"/>
        <PathGeometry x:Key="WheelRightWedge" Figures="M 67.46,16.54 A 36,36 0 0,1 67.46,67.46 L 52.61,52.61 A 15,15 0 0,0 52.61,31.39 Z"/>
        <PathGeometry x:Key="WheelBottomWedge" Figures="M 67.46,67.46 A 36,36 0 0,1 16.54,67.46 L 31.39,52.61 A 15,15 0 0,0 52.61,52.61 Z"/>
        <PathGeometry x:Key="WheelLeftWedge" Figures="M 16.54,67.46 A 36,36 0 0,1 16.54,16.54 L 31.39,31.39 A 15,15 0 0,0 31.39,52.61 Z"/>
    </UserControl.Resources>

    <Grid x:Name="DragRoot"
          Background="#01FFFFFF"
          PreviewMouseLeftButtonDown="DragRoot_PreviewMouseLeftButtonDown"
          PreviewMouseMove="DragRoot_PreviewMouseMove"
          PreviewMouseLeftButtonUp="DragRoot_PreviewMouseLeftButtonUp"
          PreviewMouseWheel="DragRoot_PreviewMouseWheel"
          LostMouseCapture="DragRoot_LostMouseCapture">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="44"
                Background="Transparent">
            <StackPanel Width="300" Background="Transparent">
                <Grid x:Name="RingHostGrid" Width="300" Height="300" Background="Transparent">
                    <Border x:Name="RingDragPad"
                            Background="#01FFFFFF"
                            Panel.ZIndex="0"
                            PreviewMouseLeftButtonDown="RingDragPad_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="RingDragPad_PreviewMouseMove"
                            PreviewMouseLeftButtonUp="RingDragPad_PreviewMouseLeftButtonUp"/>
                    <Viewbox x:Name="RingViewHost"
                             Stretch="Uniform"
                             Panel.ZIndex="1"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch">
                        <component:JukeboxRingView x:Name="RingView"
                                                   Width="300" Height="300"
                                                   DataContext="{Binding}"
                                                   MiniPlayerMode="True"/>
                    </Viewbox>
                </Grid>

                <!-- 84×84 hosts reserve equal space for 4-way wheels on both corners. -->
                <Grid Height="84" Background="Transparent">
                    <StackPanel HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Grid Width="84" Height="84">
                            <Canvas x:Name="LockWheelOverlay"
                                    Width="84"
                                    Height="84"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <Ellipse Width="80" Height="80"
                                         Canvas.Left="2" Canvas.Top="2"
                                         Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="1.5"
                                         IsHitTestVisible="False"/>
                                <Line X1="42" Y1="8" X2="42" Y2="76" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
                                <Line X1="8" Y1="42" X2="76" Y2="42" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>

                                <Path x:Name="LockWheelClearArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelLeftWedge}" IsHitTestVisible="False"/>
                                <Path x:Name="LockWheelResetArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelRightWedge}" IsHitTestVisible="False"/>
                                <Path x:Name="LockWheelMaximizeArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelTopWedge}" IsHitTestVisible="False"/>
                                <Path x:Name="LockWheelHopsArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelBottomWedge}" IsHitTestVisible="False"/>

                                <TextBlock x:Name="LockWheelClearLabel" Text="Clear" Canvas.Left="10" Canvas.Top="36" FontSize="8" Foreground="#AAFFFFFF" Opacity="0.45" IsHitTestVisible="False"/>
                                <TextBlock x:Name="LockWheelResetLabel" Text="Reset" Canvas.Left="58" Canvas.Top="36" FontSize="8" Foreground="#AAFFFFFF" Opacity="0.45" IsHitTestVisible="False"/>
                                <TextBlock x:Name="LockWheelMaximizeLabel" Text="Restore" Canvas.Left="28" Canvas.Top="10" FontSize="8" Foreground="#AAFFFFFF" Opacity="0.45" IsHitTestVisible="False"/>
                                <TextBlock x:Name="LockWheelHopsLabel" Text="Hops" Canvas.Left="34" Canvas.Top="62" FontSize="8" Foreground="#AAFFFFFF" Opacity="0.45" IsHitTestVisible="False"/>
                            </Canvas>

                            <ToggleButton x:Name="LockToggle"
                                          Style="{StaticResource MiniPlayerLockToggleStyle}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ToolTip="Tap: locks only · Hold + drag: wheel"
                                          IsChecked="{Binding JukeboxLocksOnly}"
                                          PreviewMouseLeftButtonDown="LockToggle_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="LockToggle_PreviewMouseMove"
                                          PreviewMouseLeftButtonUp="LockToggle_PreviewMouseLeftButtonUp">
                                <TextBlock Text="&#xE72E;" Style="{StaticResource TransportGlyphStyle}" FontSize="10"/>
                            </ToggleButton>
                        </Grid>

                        <TextBlock Text="{Binding RingLockCount}" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="9" Foreground="#FFD166" IsHitTestVisible="False"/>
                        <Ellipse x:Name="HopModeIndicator" Width="6" Height="6" Margin="4,0,0,0" VerticalAlignment="Center" Fill="#FFD166" Visibility="Collapsed" IsHitTestVisible="False"/>
                    </StackPanel>

                    <Grid Width="84" Height="84" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Canvas x:Name="TransportWheelOverlay"
                                Width="84"
                                Height="84"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <Ellipse Width="80" Height="80"
                                     Canvas.Left="2" Canvas.Top="2"
                                     Fill="Transparent" Stroke="#55FFFFFF" StrokeThickness="1.5"
                                     IsHitTestVisible="False"/>
                            <Line X1="8" Y1="42" X2="76" Y2="42" Stroke="#22FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>

                            <Path x:Name="TransportWheelPrevArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelLeftWedge}" IsHitTestVisible="False"/>
                            <Path x:Name="TransportWheelNextArc" Fill="Transparent" Stroke="Transparent" Data="{StaticResource WheelRightWedge}" IsHitTestVisible="False"/>

                            <TextBlock x:Name="TransportWheelPrevLabel" Text="Prev" Canvas.Left="10" Canvas.Top="36" FontSize="8" Foreground="#AAFFFFFF" Opacity="0.45" IsHitTestVisible="False"/>
                            <TextBlock x:Name="TransportWheelNextLabel" Text="Next" Canvas.Left="58" Canvas.Top="36" FontSize="8" Foreground="#AAFFFFFF" Opacity="0.45" IsHitTestVisible="False"/>
                        </Canvas>

                        <Button x:Name="TransportButton"
                                Style="{StaticResource MiniPlayerWheelButtonStyle}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ToolTip="Tap: play/pause · Hold + drag: prev / next"
                                PreviewMouseLeftButtonDown="TransportButton_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="TransportButton_PreviewMouseMove"
                                PreviewMouseLeftButtonUp="TransportButton_PreviewMouseLeftButtonUp">
                            <TextBlock FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TransportGlyphStyle}">
                                        <Setter Property="Text" Value="&#xE768;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowPauseIcon}" Value="True">
                                                <Setter Property="Text" Value="&#xE769;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
