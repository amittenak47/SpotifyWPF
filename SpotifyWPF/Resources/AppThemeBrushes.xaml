<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#000000"/>
  <SolidColorBrush x:Key="AppSurfaceBrush" Color="#0A0A0A"/>
  <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#121212"/>
  <SolidColorBrush x:Key="AppBorderBrush" Color="#1DB954"/>
  <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#A0A0A0"/>
  <SolidColorBrush x:Key="AppDisabledForegroundBrush" Color="#4A4A4A"/>
  <SolidColorBrush x:Key="AppHoverBrush" Color="#1A1A1A"/>
  <SolidColorBrush x:Key="AppSelectedBrush" Color="#169C46"/>
  <SolidColorBrush x:Key="AppAccentBrush" Color="#1DB954"/>
  <SolidColorBrush x:Key="SpotifyGreenBrush" Color="#1DB954"/>
  <SolidColorBrush x:Key="SpotifyGreenLineBrush" Color="#1DB954"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0A0A0A"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#121212"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#4A4A4A"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#169C46"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#121212"/>
</ResourceDictionary>
