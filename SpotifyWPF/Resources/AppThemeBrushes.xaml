<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#121212"/>
  <SolidColorBrush x:Key="AppSurfaceBrush" Color="#181818"/>
  <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#242424"/>
  <SolidColorBrush x:Key="AppBorderBrush" Color="#3A3A3A"/>
  <SolidColorBrush x:Key="AppForegroundBrush" Color="#E0E0E0"/>
  <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#B3B3B3"/>
  <SolidColorBrush x:Key="AppDisabledForegroundBrush" Color="#7A7A7A"/>
  <SolidColorBrush x:Key="AppHoverBrush" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="AppSelectedBrush" Color="#1F6F43"/>
  <SolidColorBrush x:Key="SpotifyGreenBrush" Color="#1DB954"/>
  <SolidColorBrush x:Key="SpotifyGreenLineBrush" Color="#1F6F43"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#242424"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F5F5F5"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#242424"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F5F5F5"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#7A7A7A"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1F6F43"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F5F5F5"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2D2D2D"/>
</ResourceDictionary>
